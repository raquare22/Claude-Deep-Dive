import re
from src.hookReport.spaceIdRowHtml import spaceIdRowHtml
from src.util.utils import hook
from src.util.clientName import getClient

def searchHook(id):
    hooks = []
    cursor = hook.find({"spaceId": id})
    cursor_bounceEmail = hook.find({"hook.action.config.spaceId": str(id)})

    for rec in cursor:
        tempId = rec['spaceId']
        tempName = rec['hook']['name']
        tempStatus = rec['status']
        if tempName != "preposthook" and tempName != "prepostrealtimehook":
            temp = rec['hook']['action']['config']['search_window']
            tempStartWindow = int(re.findall("\d+", temp)[0])
            tempEndWindow = int(re.findall("\d+", temp)[1])
        else:
            tempStartWindow = int(rec['hook']['action']['config']['search_window']['start_date_offset']['time_window'])
            tempEndWindow = int(rec['hook']['action']['config']['search_window']['end_date_offset']['time_window'])

        hooks.append((tempId, tempName, tempStartWindow, tempEndWindow, tempStatus))

    for rec in cursor_bounceEmail:
        if rec['hook']['name'] == "BouncedEmailPostProcessingHook":
            t = rec['hook']['action']['config']['search_window']
            hooks.append((rec['hook']['action']['config']['spaceId'], rec['hook']['name'],int(re.findall("\d+", t)[0]) , int(re.findall("\d+", t)[1]), rec['status']))

    return hooks

def _populate_spaceIdsRowHtml(spaceIds):

    spaceIdRowHtmlTags = ""

    for spaceId in spaceIds:
        rec = searchHook(spaceId)
        for i in rec:
            if i[4] != "AVAILABLE":
                spaceIdRowHtmlTags = spaceIdRowHtmlTags + spaceIdRowHtml.format("red", spaceId, getClient(spaceId), i[1], i[2], i[3], i[4])
            else:
                spaceIdRowHtmlTags = spaceIdRowHtmlTags + spaceIdRowHtml.format("", spaceId, getClient(spaceId), i[1], i[2], i[3], i[4])


    return spaceIdRowHtmlTags
























