# - approval.prompt: true or false
# - approval.version.required: true or false / depends on approval.prompt
#    if you want the prompt includes a version text box, set required to true.
# - approval.version.defaultDisplay: "current","blank" or any other text
#    If version.required is true, then a version will be displayed
#    that can be overwritten. The value entered for the defaultDisply property will be what
#    is displayed to the user. If you want to display the current build version, either do not set
#    a value or use a value of "current". If you want a blank version, enter "blank" or you can enter
#    anything you want to be displayed.
#    Note: Upon pressing proceed, if version.required is true, the version entered, will be evaluated
#    against the current build version and if incorrect, the build will be aborted.
# - approval.timeout.minutes: the amount of time in minuted until the build is automatically aborted due to
#   the time limit being exceeded.
approval:
  prompt: false
  version:
    required: true
    defaultDisplay: current
  timeout:
    minutes: 20160

