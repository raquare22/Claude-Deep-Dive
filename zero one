zone: core
# Container port information, this is the port opened to your api
containerPorts:
  - name: http
    protocol: TCP
    containerPort: 8080

# The number of deployment revisions to retain
revisionHistoryLimit: 5

# HealthCheck Liveness Probe
livenessProbe:
  httpGet:
    path: "/"
    port: 8080
  initialDelaySeconds: 120
  periodSeconds: 5
  timeoutSeconds: 15
# HealthCheck Readiness Probe
readinessProbe:
  httpGet:
    path: "/"
    port: 8080
  initialDelaySeconds: 120
  periodSeconds: 60
  timeoutSeconds: 15
  failureThreshold: 10


# Volumes
# volumes.name: the volume name to define the volume on the pod that your container will use
# volumes.mountPath: the path to mount the volume to (the path your app will use)
# volumes.claimName: the claimName is the name of the persistent volume claim setup within the namespace
# For our apps, some default volumes have already been defined for you.
# Also, a default logs volume will created and mounted to a pvc named "logs-appname-env"
# and mounted to /app/logs, primarily for newrelic data
volumes:
  - name: prun-log
    mountPath: /prun-log
  - name: prun-pv
    mountPath: /ingest
  - name: prun-pv
    mountPath: /prun-pv
  - name: prun-ehcache-pv
    mountPath: /prun-ehcache-pv
  - name: kafka
    mountPath: /mnt/data

nodeSelector: {}
tolerations: []
affinity: {}

