#!/bin/bash
set -e

ls -al scripts/
chmod +x "$0"

# Parse arguments
while [[ $# -gt 0 ]]; do
  key="$1"
  case $key in
    --complianceApiUrl) COMPLIANCE_API_URL="$2"; shift; shift ;;
    --reportId) REPORT_ID="$2"; shift; shift ;;
    *) echo "Unknown option $1"; exit 1 ;;
  esac
done

: "${COMPLIANCE_API_URL:?Missing --complianceApiUrl}"
: "${REPORT_ID:?Missing --reportId}"

MAX_WAIT_MINUTES=${MAX_WAIT_MINUTES:-60}
POLL_INTERVAL=20

end_time=$(( $(date +%s) + MAX_WAIT_MINUTES * 60 ))

while [ $(date +%s) -lt $end_time ]; do
  echo "Calling: $COMPLIANCE_API_URL/api/report/$REPORT_ID"
  response=$(curl -v -s -w "\n%{http_code}" "$COMPLIANCE_API_URL/api/report/$REPORT_ID" || true)
  body=$(echo "$response" | head -n -1)
  code=$(echo "$response" | tail -n1)

  # Debug output
    echo "HTTP code: $code"
    echo "Response body: $body"

  case "$code" in
    202|200|203)
      echo "CM1CM2 report ready or precheck complete."
      exit 0
      ;;
    406|400)
      echo "Error in CM1CM2 report: $body"
      exit 2
      ;;
    404|102)
      echo "Report not ready (HTTP $code), retrying in $POLL_INTERVAL seconds..."
      sleep $POLL_INTERVAL
      ;;
    *)
      echo "Unexpected response: $code $body"
      sleep $POLL_INTERVAL
      ;;
  esac
done

echo "Timed out waiting for CM1CM2 report."
exit 1





























#!/bin/bash
set -e

ls -al scripts/
chmod +x "$0"

# Parse arguments
while [[ $# -gt 0 ]]; do
  key="$1"
  case $key in
    --complianceApiUrl) COMPLIANCE_API_URL="$2"; shift; shift ;;
    --reportId) REPORT_ID="$2"; shift; shift ;;
    --time) TIME="$2"; shift; shift ;;
    --unit) UNIT="$2"; shift; shift ;;
    *) echo "Unknown option $1"; exit 1 ;;
  esac
done

: "${COMPLIANCE_API_URL:?Missing --complianceApiUrl}"
: "${REPORT_ID:?Missing --reportId}"

TIME=${TIME:-1}
UNIT=${UNIT:-DAYS}

case "$UNIT" in
  SECONDS) max_wait=$((TIME));;
  MINUTES) max_wait=$((TIME * 60));;
  HOURS)   max_wait=$((TIME * 3600));;
  DAYS)    max_wait=$((TIME * 86400));;
  *) echo "Invalid unit: $UNIT"; exit 1;;
esac

POLL_INTERVAL=100
end_time=$(( $(date +%s) + max_wait ))

while [ $(date +%s) -lt $end_time ]; do
  response=$(curl -s -w "\n%{http_code}" "$COMPLIANCE_API_URL/api/report/$REPORT_ID/approvalstatus")
  body=$(echo "$response" | head -n -1)
  code=$(echo "$response" | tail -n1)

  case "$code" in
    200)
      echo "CM3 approvals complete."
      exit 0
      ;;
    406|400|424)
      echo "Error in CM3 approval: $body"
      exit 2
      ;;
    202)
      echo "Approval not ready, retrying in $POLL_INTERVAL seconds..."
      sleep $POLL_INTERVAL
      ;;
    *)
      echo "Unexpected response: $code $body"
      sleep $POLL_INTERVAL
      ;;
  esac
done

echo "Timed out waiting for CM3 approval."
exit 1



































