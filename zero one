from src.util.dateValues import get_hcr_report_date_6hrwin
from src.util.constants import SPACE_IDS

def _generate_message(receiverEmail) -> MIMEMultipart:
    SUBJECT = 'HCR report [6 Hrs Window] for paperless clients for ' + get_hcr_report_date_6hrwin() + "."
    print("starting querying data for spaceIds..")
    fmtMail = head + _populate_spaceIdsHtmlTotal(SPACE_IDS) + _populate_spaceIdsRowHtml(SPACE_IDS) + tail
    message = MIMEMultipart("alternative", None, [MIMEText(fmtMail, 'html')])
    message['Subject'] = SUBJECT
    message['From'] = SENDER_EMAIL
    message['To'] = ", ".join(receiverEmail)
    return message


def send_message():
    print("job started : ", datetime.now())
    message = _generate_message(RECEIVER_EMAIL)
    server = smtplib.SMTP(SERVER)
    server.ehlo()
    server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, message.as_string())
    server.quit()
    print("job completed at :", datetime.now())


