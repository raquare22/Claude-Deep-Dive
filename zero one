from calendar import monthrange
from datetime import datetime, timedelta
import smtplib
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from src.ADTReport.tableHead import head
from src.ADTReport.tableTail import tail
from src.util.utils import SERVER, SENDER_EMAIL, ADT_RECEIVER_EMAIL, document
from src.ADTReport.tableHeadDataHtml1 import headData1
from src.ADTReport.mailTail import mailTail



def get_previous_month_year():
    today = datetime.utcnow()
    first_of_this_month = today.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    last_of_prev_month = first_of_this_month - timedelta(seconds=1)
    return last_of_prev_month.year, last_of_prev_month.month


def get_monthly_notification_counts(year, month, space_id):
    import traceback
    first_day = datetime(year, month, 1)
    last_day = datetime(year, month, monthrange(year, month)[1], 23, 59, 59)
    # Bounced: sendEmailNotifications true, eDeliveryError contains 'bounce'
    try:
        bounced_count = document.count_documents({
            "spaceId": space_id,
            "dateCreated": {"$gte": first_day, "$lte": last_day},
            "metadata.sendEmailNotifications": True,
            "metadata.eDeliveryError": {"$regex": "bounce", "$options": "i"}
        })
    except Exception as e:
        print("Exception in bounced_count query:", e)
        traceback.print_exc()
        bounced_count = -1
    # Successful: sendEmailNotifications true, providerEmailId is not empty, split into 5-day intervals
    successful_count = 0
    interval_start = first_day
    while interval_start < last_day:
        interval_end = min(interval_start + timedelta(days=4, hours=23, minutes=59, seconds=59), last_day)
        try:
            successful_count += document.count_documents({
                "spaceId": space_id,
                "dateCreated": {"$gte": interval_start, "$lte": interval_end},
                "metadata.sendEmailNotifications": True,
                "metadata.providerEmailId": {"$ne": ""}
            })
        except Exception as e:
            print(f"Exception in successful_count query for interval {interval_start} to {interval_end}:", e)
            traceback.print_exc()
        interval_start = interval_end + timedelta(seconds=1)
    return first_day.strftime("%B %Y"), bounced_count, successful_count


def _generate_message(receiverEmail) -> MIMEMultipart:
    SUBJECT = 'ADT Notifications Monthly Report'
    year, month = get_previous_month_year()
    space_id = 11903
    month_label, bounced, successful = get_monthly_notification_counts(year, month, space_id)
    # Build table row for previous month
    rows = f"<tr><td>{month_label}</td><td>{bounced}</td><td>{successful}</td></tr>\n"
    # Build the email HTML (only pass the date/time to headData1)
    table_html = head + headData1.format(datetime.utcnow()) + rows + tail + mailTail
    message = MIMEMultipart("alternative", None, [MIMEText(table_html, 'html')])
    message['Subject'] = SUBJECT
    message['From'] = SENDER_EMAIL
    message['To'] = ", ".join(receiverEmail)
    return message


def send_failed_status():
    message = _generate_message(ADT_RECEIVER_EMAIL)
    server = smtplib.SMTP(SERVER)
    server.ehlo()
    server.sendmail(SENDER_EMAIL, ADT_RECEIVER_EMAIL, message.as_string())
    server.quit()


if __name__ == '__main__':
    print("job started via cron : ", datetime.now())
    send_failed_status()
    print("job completed at :", datetime.now())








































