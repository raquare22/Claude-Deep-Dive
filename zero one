name: cicd-pipeline
on:
  push:
    branches:
      - main
      - develop
      - release/*
  workflow_dispatch:
    secrets:
      JFROG_USERNAME:
        description: 'JFrog username'
        required: true
      JFROG_SECRET:
        description: 'JFrog secret token'
        required: true
      KUBECONFIG:
        description: 'Kubeconfig for kubectl'
        required: true
      STAGE_VAULT_ROLE_ID:
        description: 'Vault role ID for stage environment'
        required: true
      STAGE_VAULT_SECRET_ID:
        description: 'Vault secret ID for stage environment'
        required: true


jobs:
  build-and-push:
    runs-on: uhg-runner
    outputs:
      BUILD_VERSION: ${{ steps.version.outputs.BUILD_VERSION }}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Fetch version from pyproject.toml
        id: version
        run: |
          VERSION=$(grep -oP '(?<=^version = ")[^"]*' pyproject.toml)
          echo "BUILD_VERSION=$VERSION" >> $GITHUB_ENV
          echo "BUILD_VERSION=$VERSION" >> $GITHUB_OUTPUT
          echo "Build version: $VERSION"

      - name: Log in to JFrog Artifactory Docker Registry
        env: 
          JFROG_USERNAME: ${{ secrets.JFROG_USERNAME }}
          JFROG_SECRET: ${{ secrets.JFROG_SECRET }}
        uses: docker/login-action@v3
        with:
          registry: centraluhg.jfrog.io
          username: ${{ env.JFROG_USERNAME }}
          password: ${{ env.JFROG_SECRET }}

      - name: Build and push Docker image
        id: build-push
        uses: docker/build-push-action@v5
        env:
          JFROG_USERNAME: ${{ secrets.JFROG_USERNAME }}
          JFROG_SECRET: ${{ secrets.JFROG_SECRET }}
        with:
          context: .
          file: Dockerfile
          push: true
          tags: centraluhg.jfrog.io/ppl-docker-np-loc/ppl/ppl-prun-utils:${{ env.BUILD_VERSION }}
          secrets: |
            JFROG_USERNAME=${{ env.JFROG_USERNAME }}
            JFROG_SECRET=${{ env.JFROG_SECRET }}

  deployment:
    runs-on: uhg-runner
    needs: build-and-push
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up kubectl
        uses: azure/setup-kubectl@v3
        with:
          version: 'latest'

      - name: Configure kubectl and apply deployment
        env:
          BUILD_VERSION: ${{ needs.build-and-push.outputs.BUILD_VERSION }}
          KUBECONFIG: ${{ secrets.KUBECONFIG }}
          STAGE_VAULT_ROLE_ID: ${{ secrets.STAGE_VAULT_ROLE_ID }}
          STAGE_VAULT_SECRET_ID: ${{ secrets.STAGE_VAULT_SECRET_ID }}
        run: |
          set -e

          echo $BUILD_VERSION

          echo ${{ needs.build-and-push.outputs.BUILD_VERSION }}

          mkdir -p $HOME/.kube
          echo "$KUBECONFIG" > $HOME/.kube/config
          export KUBECONFIG=$HOME/.kube/config

          docker_image='edgeinternal1uhg.optum.com/ppl-docker-np-loc/ppl/ppl-prun-utils:${{ needs.build-and-push.outputs.BUILD_VERSION }}'

          echo ${docker_image}

          sed -i "s/@vault_role_id/${{ env.STAGE_VAULT_ROLE_ID }}/g" deployment/deployment.yml

          sed -i "s/@vault_secret_id/${{ env.STAGE_VAULT_SECRET_ID }}/g" deployment/deployment.yml

          sed -i "s,@docker_image,$docker_image,g" deployment/deployment.yml

          cat deployment/deployment.yml

          kubectl config get-contexts --kubeconfig $HOME/.kube/config

          kubectl config use-context ctcnonprdusr101-admin-token_provider-paperless-stage

          kubectl auth whoami

          kubectl get pods

          kubectl apply -f deployment/deployment.yml
        shell: bash

































