from pymongo import MongoClient, errors as pymongo_errors
from datetime import datetime, timedelta
import logging as logger
import pytz
from dotenv import load_dotenv
import os
import traceback
from src.mongoCleanup.config import DATABASE_NAME, COLLECTIONS


load_dotenv()

def cleanup_collections():
    try:

        # Connect to the MongoDB
        MONGO_URI = os.getenv("MONGO_URI_PRD")
        client = MongoClient(MONGO_URI)
        if client is None:
            logger.error(f"Mongo client is None, \n  Traceback: {traceback.format_exc()}")
            return
        else:
            logger.info("Mongo client connected successfully")
        db = client[DATABASE_NAME]
        if db is None:
            logger.error(f"Mongo database not initialised, \n  Traceback: {traceback.format_exc()}")
            return
        else:
            logger.info("Mongo database connected successfully")

        for collection_name, duration_days in COLLECTIONS.items():
            collection = db[collection_name]
            if collection is None:
                logger.error(f"Mongo collection {collection_name} is None, \n  Traceback: {traceback.format_exc()}")
                return
            else:
                logger.info(f"Mongo collection {collection_name} connected successfully")
            logger.info(f"Cleaning up {collection_name} collection")
            cutoff_date = datetime.now(pytz.UTC) - timedelta(days=duration_days)
            query = {"dateCreated": {"$lt": cutoff_date}}
            logger.info("Running cleanup query: " + str(query))
            logger.info(f"Deleting documents older than {cutoff_date} from {collection_name}")
            result = collection.delete_many(query)
            logger.info(f"Deleted {result.deleted_count} documents from {collection_name}")

    except pymongo_errors.OperationFailure as e:
        logger.error(f"Mongo Cleanup Operation failed: Operation Failed: {e}, \n  Traceback: {traceback.format_exc()}")
    except pymongo_errors.ConnectionFailure as e:
        logger.error(f"Mongo Cleanup Operation failed: Connection Failed: {e}, \n  Traceback: {traceback.format_exc()}")
    except pymongo_errors.InvalidURI as e:
        logger.error(f"Mongo Cleanup Operation failed: Invalid URI: {e}, \n  Traceback: {traceback.format_exc()}")
    except pymongo_errors.ConfigurationError as e:
        logger.error(f"Mongo Cleanup Operation failed: Configuration Error: {e}, \n Traceback: {traceback.format_exc()}")
    except pymongo_errors.NetworkTimeout as e:
        logger.error(f"Mongo Cleanup Operation failed: Network Timed-out: {e}, \n Traceback: {traceback.format_exc()}")
    except Exception as e:
        logger.error(f"Mongo Cleanup Operation failed: Unexpected Error Occured: {e}, \n Traceback: {traceback.format_exc()}")





































import os
import logging
import sys
from datetime import datetime, timedelta
from pathlib import Path
from smb.SMBConnection import SMBConnection

sys.path.append(str(Path(__file__).resolve().parents[1]))
from bdpass.vaultconnection import vault_service

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)


class NASCleanup:
    def __init__(self):
        vault_service.update_app_config()
        self.smb_user = self._get_required_env("SMB_USERNAME")
        self.smb_pass = self._get_required_env("SMB_PASSWORD")
        self.nas_server = self._get_required_env("NAS_SERVER")
        self.nas_share = self._get_required_env("NAS_SHARE")
        self.cleanup_folder = os.getenv("NAS_CLEANUP_FOLDER", "out")
        self.days_old = int(self._get_required_env("NAS_CLEANUP_DAYS"))
        self.conn = None
        self.deleted = 0
        self.failed = 0
        self.log_dir = os.getenv('NAS_LOG_DIR', '/tmp/nas_cleanup_logs')
        self.timestamp = datetime.now().strftime('%Y-%m-%d-%H-%M-%S')
        self.logfile = f"{self.log_dir}/deleted_files_{self.timestamp}.log"

    def connect(self):
        """Connect to NAS via SMB"""
        try:
            logger.info(f"Connecting to {self.nas_server}/{self.nas_share}")
            # It tries two SMB connection modes. First it attempts SMB over TCP on port 445 (most common). If that fails, it retries NetBIOS/SMB on port 139. This makes the script work in more environments.
            self.conn = SMBConnection(self.smb_user, self.smb_pass, 'cleanup', self.nas_server, 
                                     use_ntlm_v2=True, is_direct_tcp=True)
            if not self.conn.connect(self.nas_server, 445):
                self.conn = SMBConnection(self.smb_user, self.smb_pass, 'cleanup', self.nas_server, 
                                         use_ntlm_v2=True, is_direct_tcp=False)
                if not self.conn.connect(self.nas_server, 139):
                    raise Exception("Connection failed")
            logger.info("Connected successfully")
            return True
        except Exception as e:
            logger.error(f"Connection error: {e}")
            return False

    def cleanup_path(self, path, cutoff):
        """Recursively delete old files"""
        try:
            items = self.conn.listPath(self.nas_share, path)
            for item in items:
                if item.filename in ['.', '..']:
                    continue
                    
                item_path = f'{path}/{item.filename}'
                if self._is_skipped_path(item_path):
                    continue
                
                if item.isDirectory:
                    self.cleanup_path(item_path, cutoff)
                else:
                    file_time = datetime.fromtimestamp(item.last_write_time)
                    if file_time < cutoff:
                        try:
                            self.conn.deleteFiles(self.nas_share, item_path)
                            self.deleted += 1
                            logger.info(f"Deleted: {item_path}")
                            self._write_log(f"Deleted: {item_path}")
                        except Exception as e:
                            self.failed += 1
                            logger.error(f"Failed: {item_path} - {e}")
                            self._write_log(f"Failed: {item_path} - {e}")
        except Exception as e:
            logger.error(f"Error in {path}: {e}")
            self._write_log(f"Error in {path}: {e}")

    def count_old_files(self, path, cutoff):
        """Recursively count old files without deleting"""
        count = 0
        try:
            items = self.conn.listPath(self.nas_share, path)
            for item in items:
                if item.filename in ['.', '..']:
                    continue

                item_path = f'{path}/{item.filename}'
                if self._is_skipped_path(item_path):
                    continue

                if item.isDirectory:
                    count += self.count_old_files(item_path, cutoff)
                else:
                    file_time = datetime.fromtimestamp(item.last_write_time)
                    if file_time < cutoff:
                        count += 1
        except Exception as e:
            logger.error(f"Error in {path}: {e}")
            self._write_log(f"Error in {path}: {e}")
        return count

    def _is_skipped_path(self, path):
        parts = [p for p in path.split('/') if p]
        for part in parts:
            if part.startswith('.'):
                return True
        return False

    def _get_required_env(self, key):
        value = os.getenv(key)
        if value is None or str(value).strip() == "":
            raise ValueError(f"Missing required environment variable: {key}")
        return value

    def _write_log(self, message):
        try:
            os.makedirs(self.log_dir, exist_ok=True)
            with open(self.logfile, 'a') as log_file:
                log_file.write(f"{datetime.now().isoformat()} - {message}\n")
        except Exception as e:
            logger.error(f"Log write failed: {e}")


    def run_cleanup(self):
        """Main cleanup process"""
        logger.info("Starting NAS cleanup")
        
        if not self.connect():
            return False
        
        try:
            cutoff = datetime.now() - timedelta(days=self.days_old)
            if os.getenv('NAS_COUNT_ONLY', 'false').lower() == 'true':
                total = self.count_old_files(f'/{self.cleanup_folder}', cutoff)
                logger.info(f"Files older than {self.days_old} days: {total}")
                self._write_log(f"Count - Older than {self.days_old} days: {total}")
                return True

            logger.info(f"Deleting files older than {self.days_old} days from /{self.cleanup_folder}")

            self.cleanup_path(f'/{self.cleanup_folder}', cutoff)

            logger.info(f"Cleanup completed - Deleted: {self.deleted}, Failed: {self.failed}")
            self._write_log(f"Summary - Deleted: {self.deleted}, Failed: {self.failed}")
            return True
        except Exception as e:
            logger.error(f"Error: {e}")
            return False
        finally:
            if self.conn:
                self.conn.close()


def cleanup_nas():
    try:
        return NASCleanup().run_cleanup()
    except Exception as e:
        logger.error(f"Failed: {e}")
        return False


if __name__ == "__main__":
    cleanup_nas()

