from datetime import datetime, timedelta, date
from src.bdpass.bdpassUtil import formatAMPM, getStrDate, record_Ind_835, record_EFT_Ind, record_default
from pymongo import MongoClient
import sys
import os
import logging as logger

sys.path.append('.')


def bdPassDownload(spaceId, freqDays, EFT_flag):
    logger.info("starting prunDownload data for : " + str(spaceId))

    if not os.path.exists('report'):
        os.makedirs('report')

    url = os.getenv("MONGO_URI_PRD")
    client = MongoClient(url)
    dbname = client['rulesEngineStore']
    collection = dbname['document']

    currentMidNight = datetime.combine(date.today(), datetime.min.time())
    query = {
        "spaceId": spaceId,
        "dateCreated": {
            "$gte": (currentMidNight - timedelta(days=freqDays)),
            "$lt": currentMidNight
        }
    }
    logger.info(f"query ==> {query}")
    cursor = collection.find(query)

    file = open("report/FDS_RAW_" + str(spaceId) + "_" + getStrDate() + ".txt", "a")
    for doc in cursor:
        dateObj = doc.get("dateCreated")
        dateStr = str(dateObj)
        mmmdd = dateObj.strftime("%b %d")
        fullDate = mmmdd + formatAMPM(datetime.fromisoformat(dateStr))

        if spaceId == 10403 and str(doc.get("metadata").get("Ind_835")) != "None":
            record = record_Ind_835(doc, fullDate)

        elif EFT_flag == True:
            record = record_EFT_Ind(doc, fullDate)

        else:
            record = record_default(doc, fullDate)

        # print("this a RECORD : ", record)
        file.write(record)
    file.close()































from datetime import datetime, timedelta


def formatAMPM(date):
    hours = date.hour
    minutes = date.minute
    seconds = date.second
    year = date.year
    ampm = "PM" if hours >= 12 else "AM"
    hours = hours % 12
    hours = hours if hours != 0 else 12  # the hour '0' should be '12'
    minutes = "0" + str(minutes) if minutes < 10 else minutes
    strTime = ", " + str(year) + " " + str(hours) + ":" + str(minutes) + ":" + str(seconds) + " " + str(ampm)
    return strTime


