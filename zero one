import smtplib
from datetime import datetime
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from src.hcr_24hr.hcrSpaceIdData import _populate_spaceIdsRowHtml
from src.hcr_24hr.hcrHead import head
from src.hcr_24hr.hcrSpaceIdDataTotal import _populate_spaceIdsHtmlTotal
from src.hcr_24hr.hcrTail import tail
from src.util.utils import SERVER, SENDER_EMAIL, RECEIVER_EMAIL, RECEIVER_EMAIL_LANE
from src.util.dateValues import get_hcr_report_date
from src.util.constants import SPACE_IDS

def _generate_message(receiverEmail) -> MIMEMultipart:
    SUBJECT = 'HCR report for paperless clients for ' + get_hcr_report_date() + "."
    print("starting querying data for spaceIds..")
    fmtMail = head + _populate_spaceIdsHtmlTotal(SPACE_IDS) + _populate_spaceIdsRowHtml(SPACE_IDS) + tail
    message = MIMEMultipart("alternative", None, [MIMEText(fmtMail, 'html')])
    message['Subject'] = SUBJECT
    message['From'] = SENDER_EMAIL
    message['To'] = ", ".join(receiverEmail)
    return message


def send_message():
    print("job started via cron : ", datetime.now())
    message = _generate_message(RECEIVER_EMAIL)
    server = smtplib.SMTP(SERVER)
    server.ehlo()
    server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, message.as_string())
    server.quit()
    print("job completed at :", datetime.now())


def send_message_lane():
    print("job started via cron : ", datetime.now())
    message = _generate_message(RECEIVER_EMAIL_LANE)
    server = smtplib.SMTP(SERVER)
    server.ehlo()
