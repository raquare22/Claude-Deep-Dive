# Strip the bad lines from both shell profiles
sed -i '' '/CLOUDSDK_PYTHON/d' ~/.zshrc ~/.bash_profile

# Append the correct Apple Silicon path to BOTH (zsh is your active shell, bash_profile kept consistent for any bash subshells)
echo 'export CLOUDSDK_PYTHON="/opt/homebrew/bin/python3"' >> ~/.zshrc
echo 'export CLOUDSDK_PYTHON="/opt/homebrew/bin/python3"' >> ~/.bash_profile

# Reload current shell
source ~/.zshrc

# Verify only ONE definition remains in each file, pointing at the correct path
grep -n CLOUDSDK_PYTHON ~/.zshrc ~/.bash_profile
echo "Active value: $CLOUDSDK_PYTHON"
ls -l "$CLOUDSDK_PYTHON"











