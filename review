	private String sanitiseString(String jsonStr){
		return JsonParser.parseString(jsonStr).toString();
	}

	private boolean validateHookName(String payload) throws JsonProcessingException {
		Map<String, Object> requestMap = objectMapper.readValue(payload, new TypeReference<>() {});
		Map hook = (Map) requestMap.get("hook");
		return SanitizeUtil.validatePayloadString((String) hook.get("name"));
	}

