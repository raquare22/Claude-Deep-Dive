	@PostMapping(value = "/run/process/prePost/{id}", consumes = MediaType.APPLICATION_JSON_VALUE)
	public ResponseEntity<GenericResponse> runPrePostProcess(@PathVariable String id, @RequestBody String payload) {
		ResponseEntity<GenericResponse> response = null;
		try {
			if(validateHookName(payload)){
				response = workflowService.runPrePostWorkflow(payload, id);
			} else {
				LOGGER.info("Invalid hook name");
				return new ResponseEntity<>(new GenericResponse(400, "Invalid hook name", response), HttpStatus.BAD_REQUEST);
			}

		} catch (HttpServerErrorException e) {
			LOGGER.error("Error: id={}; {} {}", Encode.forJava(id), e.getClass().getSimpleName(), e.getMessage());

			return new ResponseEntity<>(new GenericResponse(e.getStatusCode().value(), ERROR_DURING_PREPOST, e.getMessage()), e.getStatusCode());
		} catch (Exception e) {
			LOGGER.error("Error to process workflow, HTTPStatus={}, apiPath=/run/process/prePost/{},  error={}", HttpStatus.INTERNAL_SERVER_ERROR, Encode.forJava(id), ExceptionUtils.getStackTrace(e));

			return new ResponseEntity<>(new GenericResponse("500", ERROR_DURING_PREPOST, e.getMessage()), HttpStatus.INTERNAL_SERVER_ERROR);
		}
		
		return new ResponseEntity<>(new GenericResponse("200", "OK", HttpServletResponse.SC_OK), HttpStatus.OK);
	}
	
