	@PostMapping(value = "/run/process/csvSftp", consumes = MediaType.APPLICATION_JSON_VALUE)
	public GenericResponse runCsvSftpProcess(@RequestBody String payload) {
		
		ActivitiProcessConfig config = new ActivitiProcessConfig(payload);

		LOGGER.info("Entering runCsvSftpProcess : processConfig={}", config);
		
		var response = "";
				
		try {
			response = workflowService.runCsvWorkflow(config);
			LOGGER.info(strResponse, response);			
		} catch (HttpServerErrorException e) {
			LOGGER.error("Error: documentRecord={}; {} {}", config, e.getClass().getSimpleName(), e.getMessage());
			return new GenericResponse(e.getStatusCode().value(), "Error during runCsvSftpProcess", e.getMessage());
		} catch (Exception e) {
			LOGGER.error("Error executing POST request; documentRecord={}, error = {}", config, ExceptionUtils.getStackTrace(e));
			return new GenericResponse("400", "Error during runCsvSftpProcess", e.getMessage());
		}
		return new GenericResponse("200", "OK", response);
	}
	
