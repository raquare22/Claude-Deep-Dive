
import org.apache.commons.lang3.exception.ExceptionUtils;
import org.owasp.encoder.Encode;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Component;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.client.HttpServerErrorException;

@Component
@RestController
@RequestMapping("/api/services/v1/")
public class CSVProcessorController {

    private static final Logger LOGGER = LoggerFactory.getLogger(CSVProcessorController.class);

    private static final String INTERNAL_SERVER_ERROR = "INTERNAL_SERVER_ERROR";

    @Autowired
    private WorkflowServiceImpl workflowService;

    @PostMapping(value = "/csvProcessor", consumes = MediaType.APPLICATION_JSON_VALUE)
    public ResponseEntity<GenericResponse> postCSVProcessor(@RequestBody String jsonStr) {
        try {
            return workflowService.postCSVProcessor(jsonStr);
        } catch (HttpServerErrorException e) {
            LOGGER.error("Error: {} {}", e.getClass().getSimpleName(), e.getMessage());
            return new ResponseEntity<> (new GenericResponse(e.getStatusCode().value(), "Error during postCSVProcessor", e.getMessage()), e.getStatusCode());
        } catch (Exception ex) {
            LOGGER.error("Error posting CSV processor for error {}", ExceptionUtils.getStackTrace(ex));
            return new ResponseEntity<>(new GenericResponse("500", "Error during postCSVProcessor: " + INTERNAL_SERVER_ERROR, ex.getMessage()), HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }

    @PutMapping(value = "/csvProcessor", consumes = MediaType.APPLICATION_JSON_VALUE)
    public ResponseEntity<GenericResponse> updateCSVProcessor(@RequestBody String jsonStr) {
        try {
            return workflowService.putCSVProcessor(jsonStr);
        } catch (HttpServerErrorException e) {
            LOGGER.error("Error: {} {}", e.getClass().getSimpleName(), e.getMessage());
            return new ResponseEntity<> (new GenericResponse(e.getStatusCode().value(), "Error during updateCSVProcessor", e.getMessage()), e.getStatusCode());
        } catch (Exception ex) {
            LOGGER.error("Error updating CSV processor error={}", ExceptionUtils.getStackTrace(ex));
            return new ResponseEntity<>(new GenericResponse("500", "Error during updateCSVProcessor: " + INTERNAL_SERVER_ERROR, ex.getMessage()), HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }

    @GetMapping(value = "/csvProcessor/{id}")
    public ResponseEntity<GenericResponse> getCSVProcessorById(@PathVariable String id) {
        LOGGER.info("Entering get processor for id={}", Encode.forJava(id));
        try {
            return workflowService.getCSVProcessorById(id);
        } catch (HttpServerErrorException e) {
            LOGGER.error("Error: id={}; {} {}", Encode.forJava(id), e.getClass().getSimpleName(), e.getMessage());
            return new ResponseEntity<> (new GenericResponse(e.getStatusCode().value(), "Error during getCSVProcessorById", e.getMessage()), e.getStatusCode());
        } catch (Exception ex) {
            LOGGER.error("Error getting CSV processor for id {} and error {}", Encode.forJava(id), ExceptionUtils.getStackTrace(ex));
            return new ResponseEntity<>(new GenericResponse("500", "Error during getCSVProcessorById: " + INTERNAL_SERVER_ERROR, ex.getMessage()), HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }

    @DeleteMapping(value = "/csvProcessor/delete/{id}")
    public ResponseEntity<GenericResponse> deleteCSVProcessor(@PathVariable String id) {
        try {
            return workflowService.deleteCSVProcessorById(id);
        } catch (HttpServerErrorException e) {
            LOGGER.error("Error: {} {}", e.getClass().getSimpleName(), e.getMessage());
            return new ResponseEntity<> (new GenericResponse(e.getStatusCode().value(), "Error during deleteCSVProcessor", e.getMessage()), e.getStatusCode());
        } catch (Exception ex) {
            LOGGER.error("Error deleting CSV processor error {}", ExceptionUtils.getStackTrace(ex));
            return new ResponseEntity<>(new GenericResponse("500", "Error during deleteCSVProcessor: " + INTERNAL_SERVER_ERROR, ex.getMessage()), HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }
}
