from paramiko.ssh_exception import SSHException, AuthenticationException, NoValidConnectionsError


def uploadFilesBackup():
    try:
        host = os.getenv('BACKUP_HOST')
        password = os.getenv('BACKUP_PASSWORD')
        username = os.getenv('BACKUP_USERNAME')
        logger.info(f"Connecting with host - {host}, username - {username}")

        logger.info("Starting SSH Handshake !!")
        ssh = paramiko.SSHClient()
        # ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        keydata = os.getenv('BACKUP_KEYDATA')
        keydata_bytes = keydata.encode()
        key = paramiko.RSAKey(data=decodebytes(keydata_bytes))
        ssh.get_host_keys().add(host, 'ssh-rsa', key)
        ssh.connect(hostname=host, username=username, password=password)
        sftp = ssh.open_sftp()
        logger.info("SSH Connection started !!")

        date_yesterday = datetime.today() - timedelta(days=1)
        str_date = date_yesterday.strftime('%d-%m-%Y')
        str_month = date_yesterday.strftime('%Y') + "_" + date_yesterday.strftime('%m')

        remotepathMonth = "/app1/bdpass/BDPassData/BDPass_" + str_month + "/"
        localpath = "report/"

        create_remote_directory(sftp, remotepathMonth)

        remotepathDate = remotepathMonth + str_date + "/"

        create_remote_directory(sftp, remotepathDate)

        logger.info("Uploading files to path : %s", remotepathDate)

        upload_files_to_sftp(sftp, localpath, remotepathDate)

        sftp.close()
        ssh.close()
        logger.info("SSH Connection closed !!")

    except AuthenticationException as auth_error:
        logger.error(f"Authentication error: {auth_error}\nTraceback: {traceback.format_exc()}")
    except NoValidConnectionsError as conn_error:
        logger.error(f"Connection error: {conn_error}\nTraceback: {traceback.format_exc()}")
    except SSHException as ssh_error:
        logger.error(f"SSH error: {ssh_error}\n Traceback: {traceback.format_exc()}")
    except FileNotFoundError as fnf_error:
        logger.error(f"File not found error: {fnf_error}\n Traceback: {traceback.format_exc()}")
    except PermissionError as perm_error:
        logger.error(f"Permission error: {perm_error}\n Traceback: {traceback.format_exc()}")
    except OSError as os_error:
        logger.error(f"OS error: {os_error}\n Traceback: {traceback.format_exc()}")
    except Exception as e:
        logger.error(f"An unexpected error occurred: {e}\n Traceback: {traceback.format_exc()}")


