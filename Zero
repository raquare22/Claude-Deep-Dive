    needs: [prepare, build-and-quality-scans, prod-deployment]
    if: always() && 
      !contains(needs.*.result, 'failure') &&
      !contains(needs.*.result, 'cancelled') && (github.ref == 'refs/heads/master')
    steps:
      - name: Tag release
        uses: actions/create-release@latest
        with:
          tag_name: "v${{ needs.prepare.outputs.build_version }}"
          release_name: "Release v${{ needs.prepare.outputs.build_version }}"
          body: |
            Version ${{ needs.prepare.outputs.build_version }} ${{ needs.prepare.outputs.current_date }}




































