  deployment:
    runs-on: uhg-runner
    needs: build-and-push
    environment:
      name: approvalToDeploy
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up kubectl
        uses: azure/setup-kubectl@v3
        with:
          version: 'v1.28.5'         # pin — was 'latest'

      - name: Set up Helm
        uses: azure/setup-helm@v4
        with:
          version: 'v3.14.2'         # match the version activiti pins

      - name: Validate required secrets
        run: |
          if [ -z "${{ secrets.KUBECONFIG }}" ]; then
            echo "::error::KUBECONFIG secret missing or empty"; exit 1
          fi
          if [ -z "${{ secrets.STAGE_VAULT_ROLE_ID }}" ]; then
            echo "::error::STAGE_VAULT_ROLE_ID secret missing"; exit 1
          fi
          if [ -z "${{ secrets.STAGE_VAULT_SECRET_ID }}" ]; then
            echo "::error::STAGE_VAULT_SECRET_ID secret missing"; exit 1
          fi
        shell: bash

      - name: Configure kubectl context
        env:
          KUBECONFIG_CONTENT: ${{ secrets.KUBECONFIG }}
        run: |
          set -euo pipefail
          mkdir -p "$HOME/.kube"
          printf '%s' "$KUBECONFIG_CONTENT" > "$HOME/.kube/config"
          chmod 600 "$HOME/.kube/config"
          export KUBECONFIG="$HOME/.kube/config"
          kubectl config use-context ctcnonprdusr101-admin-token_provider-paperless-stage
          kubectl auth whoami
        shell: bash

      - name: Helm lint chart
        run: helm lint ./helm
        shell: bash

      - name: Helm dry-run (sanity render)
        env:
          BUILD_VERSION:        ${{ needs.build-and-push.outputs.BUILD_VERSION }}
          STAGE_VAULT_ROLE_ID:  ${{ secrets.STAGE_VAULT_ROLE_ID }}
          STAGE_VAULT_SECRET_ID: ${{ secrets.STAGE_VAULT_SECRET_ID }}
          KUBECONFIG: /home/runner/.kube/config
        run: |
          set -euo pipefail
          helm upgrade --install ppl-prun-utils ./helm \
            --namespace provider-paperless-stage \
            --values ./helm/values-stage.yml \
            --set image.tag="$BUILD_VERSION" \
            --set vaultRoleId="$STAGE_VAULT_ROLE_ID" \
            --set vaultSecretId="$STAGE_VAULT_SECRET_ID" \
            --dry-run
        shell: bash

      - name: Deploy to HCC K8s with Helm
        env:
          BUILD_VERSION:        ${{ needs.build-and-push.outputs.BUILD_VERSION }}
          STAGE_VAULT_ROLE_ID:  ${{ secrets.STAGE_VAULT_ROLE_ID }}
          STAGE_VAULT_SECRET_ID: ${{ secrets.STAGE_VAULT_SECRET_ID }}
          KUBECONFIG: /home/runner/.kube/config
        run: |
          set -euo pipefail
          helm upgrade --install ppl-prun-utils ./helm \
            --namespace provider-paperless-stage \
            --values ./helm/values-stage.yml \
            --set image.tag="$BUILD_VERSION" \
            --set vaultRoleId="$STAGE_VAULT_ROLE_ID" \
            --set vaultSecretId="$STAGE_VAULT_SECRET_ID" \
            --atomic \
            --wait \
            --timeout 5m
          helm history ppl-prun-utils -n provider-paperless-stage
          kubectl rollout status deployment/ppl-prun-utils \
            -n provider-paperless-stage --timeout=300s
        shell: bash
