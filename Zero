*.rendered.yml















# Default values for ppl-prun-utils.
# Anything env-specific belongs in values-<env>.yml — this file holds
# values that are the same in every environment.

# Application identity
name: ppl-prun-utils

# Environment label — overridden by each values-<env>.yml
environment: stage

# Kubernetes namespace — overridden by each values-<env>.yml
namespace: provider-paperless-stage

# Replica count
replicas: 1

# How many old ReplicaSets Kubernetes keeps for rollback
revisionHistoryLimit: 5

# Container image — repository is constant, tag is set at deploy time
# via `--set image.tag=$BUILD_VERSION` from the GitHub Actions workflow
image:
  repository: edgeinternal1uhg.optum.com/ppl-docker-np-loc/ppl/ppl-prun-utils
  tag: ""                    # MUST be supplied at deploy time
  pullPolicy: Always

# Pre-existing pull secret in the namespace
imagePullSecret: edge-docker-registry-secret

# Container port the Flask app exposes (matches main.py)
containerPort: 8080

# Compute resources — must match HCC capacity planning
resources:
  limits:
    cpu: "4"
    memory: 6Gi
  requests:
    cpu: "2"
    memory: 4Gi

# TCP-based health probes (Flask :8080 — same as today's deployment.yml)
probes:
  initialDelaySeconds: 30
  periodSeconds: 30

# Vault credentials — MUST be supplied at deploy time via --set
# Never put real values in this file (committed to Git)
vaultRoleId: ""
vaultSecretId: ""

# Update strategy — preserves today's behavior exactly
strategy:
  type: RollingUpdate
  rollingUpdate:
    maxSurge: 25%
    maxUnavailable: 25%



























