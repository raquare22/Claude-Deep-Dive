from src.mongoCleanup.cleanupScript import cleanup_collections
from src.mongoCleanup.config import MONGO_URI, DATABASE_NAME, COLLECTIONS


class TestCleanupCollections(unittest.TestCase):

    @patch("src.mongoCleanup.cleanupScript.MongoClient")
    def test_cleanup_success(self, mock_mongo_client):
        # Setup
        mock_client = MagicMock()
        mock_db = MagicMock()
        mock_collection = MagicMock()
        mock_result = MagicMock()

        mock_mongo_client.return_value = mock_client
        mock_client.__getitem__.return_value = mock_db
        mock_db.__getitem__.return_value = mock_collection
        mock_collection.delete_many.return_value = mock_result
        mock_result.deleted_count = 5

        # Capture the output and current time just before running the function
        with patch("sys.stdout", new=StringIO()) as fake_out:
            current_now = datetime.now(pytz.UTC)
            cleanup_collections()
            output = fake_out.getvalue().strip()

        # Assert
        for collection_name, duration_days in COLLECTIONS.items():
            cutoff_date = current_now - timedelta(days=duration_days)
            query = {"dateCreated": {"$lt": cutoff_date}}
            mock_collection.delete_many.assert_any_call(query)
            self.assertIn(
                f"Deleted {mock_result.deleted_count} documents from {collection_name}",
                output,
            )

    @patch("src.mongoCleanup.cleanupScript.MongoClient")
    def test_operation_failure(self, mock_mongo_client):
        # Setup
        mock_client = MagicMock()
        mock_db = MagicMock()
        mock_collection = MagicMock()

        mock_mongo_client.return_value = mock_client
        mock_client.__getitem__.return_value = mock_db
        mock_db.__getitem__.return_value = mock_collection
        mock_collection.delete_many.side_effect = pymongo_errors.OperationFailure(
            "Operation failed"
        )

        # Capture the output
        with patch("sys.stdout", new=StringIO()) as fake_out:
            cleanup_collections()
            output = fake_out.getvalue().strip()

        # Assert
        self.assertIn("Operation failed: Operation failed", output)

    @patch("src.mongoCleanup.cleanupScript.MongoClient")
    def test_unexpected_error(self, mock_mongo_client):
        # Setup
        mock_client = MagicMock()
        mock_db = MagicMock()
        mock_collection = MagicMock()

        mock_mongo_client.return_value = mock_client
        mock_client.__getitem__.return_value = mock_db
        mock_db.__getitem__.return_value = mock_collection
        mock_collection.delete_many.side_effect = Exception("Unexpected error")

        # Capture the output
        with patch("sys.stdout", new=StringIO()) as fake_out:
            cleanup_collections()
            output = fake_out.getvalue().strip()

        # Assert
        self.assertIn("Unexpected error during cleanup: Unexpected error", output)


if __name__ == "__main__":
    unittest.main()



































