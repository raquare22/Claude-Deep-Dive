def _populate_spaceIdsHtmlTotal(spaceIds):
    print("inside populate space ids html", spaceIds)
    hcr_report_date = get_hcr_report_date_6hrwin()
    startTime = get_current_midnight_6hrwin()
    endTime = get_end_time_6hrwin()
    dateCreated = get_date_created_6hrwin()
    dateCreated_10075sfly = get_date_created_6hrwin_10075sfly()
    dateCreated7 = get_date_created_7days_6hrwin()

    # Define tasks to be executed concurrently
    tasks = {
        "zipSuccessTotal": lambda: getZipSuccessTotal(spaceIds, dateCreated),
        "zipAckFileIssueTotal": lambda: getZipAckFileIssueTotal(spaceIds, dateCreated),
        "zipInProcessNewTotal": lambda: getZipInProcessNewTotal(spaceIds, dateCreated),
        "zipInProcessNewTotal7days": lambda: getZipInProcessNewTotal7days(spaceIds, dateCreated7),
        "zipInProcessInProcessTotal": lambda: getZipInProcessInProcessTotal(spaceIds, dateCreated),
        "zipInProcessInProcessTotal7days": lambda: getZipInProcessInProcessTotal7days(spaceIds, dateCreated7),
        "zipInProcessReadyTotal": lambda: getZipInProcessReadyTotal(spaceIds, dateCreated),
        "zipInProcessReadyTotal7days": lambda: getZipInProcessReadyTotal7days(spaceIds, dateCreated7),
        "zipFailureFatalErrorTotal": lambda: getZipFailureFatalErrorTotal(spaceIds, dateCreated),
        "processorFileTaskCountInProcessSuccessTotal": lambda: getProcessorFileTaskSuccessTotal(spaceIds, dateCreated),
        "processorFileTaskCountInProcessNewTotal": lambda: getProcessorFileTaskInProcessNewTotal(spaceIds, dateCreated),
        "processorFileTaskCountInProcessNewTotal7days": lambda: getProcessorFileTaskInProcessNewTotal7days(spaceIds, dateCreated7),
        "processorFileTaskCountInProcessInProcessTotal7days": lambda: getProcessorFileTaskInProcessInProcessTotal7days(spaceIds, dateCreated7),
        "processorFileTaskCountFailureSevereErrorTotal": lambda: getProcessorFileTaskFailureSevereErrorTotal(spaceIds, dateCreated),
        "processorFileTaskCountFailureFatalErrorTotal": lambda: getProcessorFileTaskFailureFatalErrorTotal(spaceIds, dateCreated),
        "prePostSuccessTotal": lambda: getPrePostSuccessTotal(spaceIds, dateCreated),
        "prePostFailure1dayTotal": lambda: getPrePostFailure1dayTotal(spaceIds, dateCreated),
        "prePostFailure7daysTotal": lambda: getPrePostFailure7daysTotal(spaceIds, dateCreated7),
        "docLibSuccessTotal": lambda: getDocLibSuccessTotal(spaceIds, dateCreated),
        "docLibLast1DayBackUpTotal": lambda: (
            getDocLibLast1DayBackUp_1Total(spaceIds, dateCreated) +
            getDocLibLast1DayBackUp_2Total(spaceIds, dateCreated) +
            getDocLibLast1DayBackUp_3Total(spaceIds, dateCreated)
        ),
        "docLibLast7DayBackUpTotal": lambda: (
            getDocLibLast7DayBackUp_1Total(spaceIds, dateCreated7) +
            getDocLibLast7DayBackUp_2Total(spaceIds, dateCreated7) +
            getDocLibLast7DayBackUp_3Total(spaceIds, dateCreated7)
        ),
        "providerEmailSuccessTotal": lambda: getProviderEmailSuccessTotal(spaceIds, dateCreated),
        "providerEmailFailureTotal": lambda: (
            getProviderEmailFailureTotal_withoutEFT(spaceIds, dateCreated) +
            getProviderEmailFailureTotal_withEFT(spaceIds, dateCreated)
        ),
        "providerEmailNotificationSuccessTotal": lambda: getProviderEmailNotificationSuccessTotal(spaceIds, dateCreated),
        "providerEmailNotificationReadyTotal1day": lambda: getProviderEmailNotificationReadyTotal1day(spaceIds, dateCreated),
        "providerEmailNotificationReadyTotal7days": lambda: getProviderEmailNotificationReadyTotal7days(spaceIds, dateCreated7),
        "providerEmailNotificationInProcessTotal1day": lambda: getProviderEmailNotificationInProcessTotal1day(spaceIds, dateCreated),
        "providerEmailNotificationInProcessTotal7days": lambda: getProviderEmailNotificationInProcessTotal7days(spaceIds, dateCreated7),
        "shutterflySuccessTotal": lambda: getShutterflySuccessTotal(spaceIds, dateCreated),
        "shutterflyFailureTotal": lambda: (
            getShutterflyFailureTotal1(spaceIds, dateCreated) +
            getShutterflyFailureTotal2_10075(spaceIds, dateCreated_10075sfly)
        ),
        "corpMPINPESCallSuccessTotal": lambda: getCorpMPINPESCallSuccessTotal(spaceIds, dateCreated),
        "corpMPINPESCallFailureValidTotal": lambda: getCorpMPINPESCallFailureValidTotal(spaceIds, dateCreated),
        "corpMPINPESCallFailureInvalidTotal": lambda: getCorpMPINPESCallFailureInvalidTotal(spaceIds, dateCreated),
        "storageErrorSuccessTotal": lambda: getStorageErrorSuccessTotal(spaceIds, dateCreated),
        "storageErrorFailureTotal1day": lambda: getStorageErrorFailureTotal1day(spaceIds, dateCreated),
        "storageErrorFailureTotal7days": lambda: getStorageErrorFailureTotal7days(spaceIds, dateCreated7),
        "responseFileSuccessTotal": lambda: getResponseFileSuccessTotal(spaceIds, dateCreated),
        "responseFileInProcessTotal": lambda: (
            getResponseFileInProcessTotal_1(spaceIds, dateCreated) +
            getResponseFileInProcessTotal_2(spaceIds, dateCreated)
        ),
        "bouncedEmailCompleteTotal": lambda: getBouncedEmailCompleteTotal(spaceIds, dateCreated),
        "bouncedEmailInProcessTotal": lambda: getBouncedEmailInProcessTotal(spaceIds, dateCreated),
        "bouncedEmailInProcess7daysTotal": lambda: getBouncedEmailInProcess7daysTotal(spaceIds, dateCreated7),
        "bouncedEmailAvailableTotal": lambda: getBouncedEmailAvailableTotal(spaceIds, dateCreated),
        "bouncedEmailAvailable7daysTotal": lambda: getBouncedEmailAvailable7daysTotal(spaceIds, dateCreated7),
    }

    # Execute tasks concurrently
    results = {}
    with ThreadPoolExecutor() as executor:
        future_to_key = {executor.submit(task): key for key, task in tasks.items()}
        for future in future_to_key:
            key = future_to_key[future]
            results[key] = future.result()

    # Format the final output
    return headData.format(
        reportDate=hcr_report_date,
        startTime=startTime,
        endTime=endTime,
        processorFileTaskCountInProcessInProcessTotal=0,
        **results
    )







