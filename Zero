            echo "USER_STORY_APPROVERS=PaperlessRulesEngine_CM1_CM2" >> $GITHUB_ENV
            echo "CM3_BUSINESS_APPROVERS=PaperlessRulesEngine_CM3_Business" >> $GITHUB_ENV
            echo "CM3_IT_APPROVERS=PaperlessRulesEngine_CM3_IT" >> $GITHUB_ENV
            echo "SECURITY_SCANS=SONAR:com.optum.fds:fds-paperless-processor-listener,SONAR:com.optum.fds:fds-paperless-activiti,SONAR:com.optum.fds:message-service,SONAR:com.optum.fds:ppl-prun-services,SONAR:com.optum.pen:pen-api,SONAR:com.optum.pen:pen-batch" >> $GITHUB_ENV
            echo "ASK_ID=UHGWM110-023810" >> $GITHUB_ENV
          elif [ "${{ github.event.inputs.application }}" = "PEN" ]; then
            echo "USER_STORY_APPROVERS=ProviderEmailNotifications_CM1_CM2" >> $GITHUB_ENV
            echo "CM3_BUSINESS_APPROVERS=ProviderEmailNotifications_CM3_Business" >> $GITHUB_ENV
            echo "CM3_IT_APPROVERS=ProviderEmailNotifications_CM3_IT" >> $GITHUB_ENV
            echo "SECURITY_SCANS=SONAR:com.optum.pen:pen-api,SONAR:com.optum.pen:pen-batch" >> $GITHUB_ENV
            echo "ASK_ID=UHGWM110-026131" >> $GITHUB_ENV
          elif [ "${{ github.event.inputs.application }}" = "PDO" ]; then
            echo "USER_STORY_APPROVERS=PaperlessDeliveryOptions_CM1_CM2" >> $GITHUB_ENV
            echo "CM3_BUSINESS_APPROVERS=PaperlessDeliveryOptions_CM3_Business" >> $GITHUB_ENV
            echo "CM3_IT_APPROVERS=PaperlessDeliveryOptions_CM3_IT" >> $GITHUB_ENV
            echo "SECURITY_SCANS=SONAR:com.optum.pdo:pdo-api,SONAR:com.optum.pdo:pdo-batch" >> $GITHUB_ENV
            echo "ASK_ID=UHGWM110-017971" >> $GITHUB_ENV
          fi
          echo "SECURITY_SCANS=${{env.SECURITY_SCANS}}"
      - name: Generate SECURITY_SCANS_PARAMETERS
        run: |
          SECURITY_SCANS_PARAMETERS=$(jq -c -n --arg scans "${{env.SECURITY_SCANS}}" '
          ($scans | split(",") | map(
           . as $scan |
           ($scan | capture("^(?<scanTool>[^:]+):(?<recordName>.+)$"))
          ) | group_by(.scanTool) | map({
           scanTool: .[0].scanTool,
           recordLabels: [],
           recordNames: map(.recordName)
          }))
          ')
          echo "SECURITY_SCANS_PARAMETERS=$SECURITY_SCANS_PARAMETERS" >> $GITHUB_ENV     
          echo "SECURITY_SCANS_PARAMETERS=$SECURITY_SCANS_PARAMETERS"
      - name: Fail if SECURITY_SCANS is empty
        run: |
          if [ -z "${{env.SECURITY_SCANS}}" ]; then
            echo "${{env.SECURITY_SCANS}} is not set"
            exit 1
          fi

