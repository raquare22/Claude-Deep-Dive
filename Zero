def searchProcessor(id):
    tempProcessor = []
    cursor = processor.find({"configSpaceId": id},
                            {"configSpaceId": 1, "status": 1, "process.config.ftp_rootdir": 1})
    for rec in cursor:
        tempId = rec['configSpaceId']
        tempStatus = rec['status']
        tempRootdr = rec['process']['config']['ftp_rootdir']
        tempProcessor.append((tempId, tempStatus, tempRootdr))

    return tempProcessor


def _populate_spaceIdsRowHtml(spaceIds):
    htmlTagResult = []
    spaceIdRowHtmlTags = ""
    spaceIdRowHtmlTagsShutdown = ""
    index1 = 1
    index2 = 1
    for spaceId in spaceIds:
        rec = searchProcessor(spaceId)

        for i in rec:
            if i[1] == "SHUTDOWN":
                spaceIdRowHtmlTagsShutdown = spaceIdRowHtmlTagsShutdown + spaceIdRowHtmlShutdown.format(index2, spaceId, getClient(spaceId), "red", i[1], i[2])
                index2 = index2 + 1
            else:
                spaceIdRowHtmlTags = spaceIdRowHtmlTags + spaceIdRowHtml.format(index1, spaceId, getClient(spaceId), "limegreen", i[1], i[2])
                index1 = index1 + 1

    htmlTagResult.append(spaceIdRowHtmlTags)
    htmlTagResult.append(spaceIdRowHtmlTagsShutdown)

    return htmlTagResult




























