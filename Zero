# Stage 1: Build Stage
# use python dev image to build the app as it has all the required tools

FROM centraluhg.jfrog.io/glb-docker-uhg-loc/uhg-goldenimages/python:3.13-latest-dev
# FROM optum-docker-auth-prod.repo1.uhc.com/chainguard/python/dev:3.13-latest-dev AS builder

# ENV PATH="/app/venv/bin:$PATH"

USER root

WORKDIR /app
ENV PATH="/venv/bin:$PATH"

#Defining package Artifactory URL
# RUN python -m pip config set global.index https://repo1.uhc.com/artifactory/api/pypi/pypi-virtual
# RUN python -m pip config set global.index-url https://repo1.uhc.com/artifactory/api/pypi/pypi-virtual/simple


# Create a new virtual environment to cleanly hold the application’s dependencies
RUN python -m venv /venv
# Copy requirements.txt from the current directory to the /app location in the container
COPY requirements.txt .

# Install all dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Uninstall pip to reduce the image size
RUN python3 -m pip uninstall -y pip

# Stage 2: Final Stage
# Use python minimal runtime image to run the app as it is lightweight
# FROM centraluhg.jfrog.io/glb-docker-uhg-loc/uhg-goldenimages/python/dev:3.13-latest-dev AS builder
# FROM optum-docker-auth-prod.repo1.uhc.com/chainguard/python:3.13-latest

# WORKDIR /app

# ENV PATH="/venv/bin:$PATH"

# # Use dev image again as it contains shell
# FROM optum-docker-auth-prod.repo1.uhc.com/chainguard/python/dev:3.13-latest-dev

# # 1) become root so we can create/chown a writable folder
# USER root
# WORKDIR /app

# # pre-create report/ and give ownership to UID 1000
# # (replace “1000:0” with non-root UID:GID if different)
# RUN mkdir -p report && chown -R 1000:0 report

# # preserve your original venv path
# ENV PATH="/venv/bin:$PATH"

RUN mkdir -p report && chown -R 1000:0 report


# 2) copy in your built venv and source
# COPY --from=builder /app/venv /venv
COPY . ./


# 3) drop back to non-root
USER 1000

ENV PYTHONUNBUFFERED=0

EXPOSE 8080

ENTRYPOINT [ "python3", "-u", "/app/main.py" ]
































#!/usr/bin/env groovy
import com.optum.jenkins.pipeline.library.utils.Constants

@Library("com.optum.jenkins.pipeline.library@v0.3.37") _


pipeline {
  agent { label 'docker-maven-slave' }
  environment {
    GIT_CREDENTIALS_ID = 'a1ca614e-2477-48a4-b0f4-24de92ef44a6'
    DOCKER_CREDENTIALS_ID = 'fds_paperless-docker-id'
    DOCKER_HOSTNAME = 'docker.repo1.uhc.com'
    DOCKER_GC_HOSTNAME = 'optum-docker-auth-prod.repo1.uhc.com'
    DOCKER_NAMESPACE = 'fds-paperless'
    DOCKER_REPO = 'ppl-prun-utils'
    DOCKER_DEV_TAG= 'latest'
    DOCKER_TEST_TAG= 'stage'
    HCC_K8S_CREDENTIALS_ID='prun-hcc-k8s-id'
    JAVA_VERSION = "11.0"
    JAVA_HOME = "/tools/java/jdk11.0"
    DOCKER_IMG = "python/dev:latest-dev"
  }

  stages {
    stage('Build/Deploy Dev Docker Image') {
      steps {
        echo 'Docker Build Dev'
        glDockerImagePull([
          image: "optum-docker-auth-prod.repo1.uhc.com/chainguard/python/dev:latest-dev",
          credentialsId: "${env.DOCKER_CREDENTIALS_ID}",
        ])
         glDockerImageBuild credentialsId: "${DOCKER_CREDENTIALS_ID}", containerRegistry:"$DOCKER_GC_HOSTNAME", image: "${env.DOCKER_HOSTNAME}/${env.DOCKER_NAMESPACE}/${env.DOCKER_REPO}:${env.DOCKER_DEV_TAG}"
         glDockerImagePush credentialsId: "${DOCKER_CREDENTIALS_ID}", image: "${env.DOCKER_HOSTNAME}/${env.DOCKER_NAMESPACE}/${env.DOCKER_REPO}:${env.DOCKER_DEV_TAG}"
      }
    }

	stage ('Deploy to HCC K8S') {
      agent { label 'docker-maven-slave' }
      steps {
        script {
          withCredentials([
                  string(credentialsId: 'VAULT_NON_PROD_ROLE_ID', variable: 'vault_role_id'),
                  string(credentialsId: 'VAULT_NON_PROD_SECRET_ID', variable: 'vault_secret_id'),
          ]) {
            sh "sed -i 's/@vault_role_id/$vault_role_id/g' deployment/deployment.yml"
            sh "sed -i 's/@vault_secret_id/$vault_secret_id/g' deployment/deployment.yml"
            glKubernetesApply(
                    credentials: "${env.HCC_K8S_CREDENTIALS_ID}",
                    clusterPort:443,
                    cluster: "hcc-ctc-nonprd-usr001-0.optum.com",
                    namespace: "provider-paperless-stage",
                    deleteIfExists:"true",
                    yamls: [
                            "./deployment/deployment.yml",
                            //   "./deployment/cron-job.yml"
                    ],
                    env: "stage",
                    isProduction: false
            )
          }
        }
      }
    }
  }


  post {
    always {
      echo 'This will always run'
      emailext body: "Build URL: ${BUILD_URL}",
        subject: "$currentBuild.currentResult-$JOB_NAME",
        to: 'jenny.j.wang@optum.com'
    }
    success {
      echo 'This will run only if successful'
    }
    failure {
      echo 'This will run only if failed'
    }
    unstable {
      echo 'This will run only if the run was marked as unstable'
    }
  }
}
































