def create_remote_directory(sftp, remotepath):
    try:
        sftp.chdir(remotepath)
    except IOError:
        sftp.mkdir(remotepath)
        sftp.chdir(remotepath)


def upload_files_to_sftp(sftp, localpath, remotepath):
    try:
        for root, dirs, files in os.walk(localpath):
            for fname in files:
                full_fname = os.path.join(root, fname)
                logger.info(f"Uploading: {full_fname}")
                sftp.put(full_fname, os.path.join(remotepath, fname))
    except FileNotFoundError as fnf_error:
        logger.error(f"File not found: {fnf_error}\n Traceback: {traceback.format_exc()}")
    except PermissionError as perm_error:
        logger.error(f"Permission error: {perm_error}\n Traceback: {traceback.format_exc()}")
    except Exception as e:
        logger.error(f"An unexpected error occurred: {e}\n Traceback: {traceback.format_exc()}")


