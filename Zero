apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Values.name }}-{{ .Values.environment }}
  namespace: {{ .Values.namespace }}
  labels:
    application: {{ .Values.name }}
    environment: {{ .Values.environment }}
    tier: app
spec:
  replicas: {{ .Values.replicas }}
  revisionHistoryLimit: {{ .Values.revisionHistoryLimit }}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 25%
      maxUnavailable: 25%
  selector:
    matchLabels:
      application: {{ .Values.name }}
      environment: {{ .Values.environment }}
  template:
    metadata:
      labels:
        application: {{ .Values.name }}
        environment: {{ .Values.environment }}
    spec:
      restartPolicy: Always
      dnsPolicy: ClusterFirst
      terminationGracePeriodSeconds: 30
      imagePullSecrets:
        - name: edge-docker-registry-secret
      containers:
        - name: {{ .Values.name }}-{{ .Values.environment }}
          image: {{ .Values.dockerImage }}
          imagePullPolicy: {{ .Values.pipeline.application.image.pullPolicy }}
          terminationMessagePath: /dev/termination-log
          ports:
            {{- if .Values.containerPorts }}
            {{- range .Values.containerPorts }}
            - name: {{ .name }}
              protocol: {{ .protocol }}
              containerPort: {{ .containerPort }}
            {{- end }}
            {{- end }}
          resources:
            limits:
              cpu: {{ .Values.resources.cpu.podLimit }}
              memory: {{ .Values.resources.memory.podLimit }}
            requests:
              cpu: {{ .Values.resources.cpu.podRequest }}
              memory: {{ .Values.resources.memory.podRequest }}
          env:
            - name: VAULT_ROLE_ID
              value: {{ .Values.vaultRoleId }}
            - name: VAULT_SECRET_ID
              value: {{ .Values.vaultSecretId }}
            - name: APP_NAME
              value: {{ .Values.name }}
            - name: ENVIRONMENT
              value: {{ .Values.environment }}
          livenessProbe:
            tcpSocket:
              port: {{ .Values.livenessProbe.port }}
            initialDelaySeconds: {{ .Values.livenessProbe.initialDelaySeconds }}
            periodSeconds: {{ .Values.livenessProbe.periodSeconds }}
            failureThreshold: {{ .Values.livenessProbe.failureThreshold }}
          readinessProbe:
            tcpSocket:
              port: {{ .Values.readinessProbe.port }}
            initialDelaySeconds: {{ .Values.readinessProbe.initialDelaySeconds }}
            periodSeconds: {{ .Values.readinessProbe.periodSeconds }}
            failureThreshold: {{ .Values.readinessProbe.failureThreshold }}
          securityContext:
            runAsUser: 1000
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            capabilities:
              drop:
                - KILL
                - MKNOD
                - SYS_CHROOT


































=== values-stage.yml
# Stage environment values for ppl-prun-utils
# This file is merged with pipeline.yml at deploy time
# The reusable deploy workflow reads helm/values-stage.yml when environment=stage

# Identity
environment: stage
name: ppl-prun-utils

# Number of pod replicas for this environment
# Keep at 1 for cron-style apps to prevent duplicate scheduled jobs
replicas: 1

# CPU and Memory limits for the pod
# request = guaranteed minimum, limit = hard ceiling
# Values match the existing deployment/deployment.yml
resources:
  memory:
    podRequest: 4Gi
    podLimit: 6Gi
  cpu:
    podRequest: "2"
    podLimit: "4"

# Liveness probe — "Is the app still alive?"
# Uses tcpSocket because Flask app has no GET / route
livenessProbe:
  port: 8080
  initialDelaySeconds: 30
  periodSeconds: 30
  failureThreshold: 3

# Readiness probe — "Is the app ready to receive traffic?"
readinessProbe:
  port: 8080
  initialDelaySeconds: 30
  periodSeconds: 30
  failureThreshold: 3

# Legacy approval flag (real approval is GitHub approvalToDeploy environment)
approval:
  prompt: true































name: cicd-pipeline

permissions:
  contents: write
  security-events: write
  id-token: write
  pull-requests: write
  issues: read
  statuses: write
  checks: write
  deployments: write
  actions: read

on:
  push:
    branches:
      - main
      - develop
      - release/*
  workflow_dispatch:

jobs:
  # Job 1: Build the Python Docker image and push to JFrog
  # We keep our own build because the reusable cicd.yml is Java/Maven only
  build-and-push:
    runs-on: uhg-runner
    outputs:
      BUILD_VERSION: ${{ steps.version.outputs.BUILD_VERSION }}
      DOCKER_IMAGE: ${{ steps.version.outputs.DOCKER_IMAGE }}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Fetch version from pyproject.toml
        id: version
        run: |
          VERSION=$(grep -oP '(?<=^version = ")[^"]*' pyproject.toml)
          echo "BUILD_VERSION=$VERSION" >> $GITHUB_ENV
          echo "BUILD_VERSION=$VERSION" >> $GITHUB_OUTPUT
          DOCKER_IMAGE="edgeinternal1uhg.optum.com/ppl-docker-np-loc/ppl/ppl-prun-utils:$VERSION"
          echo "DOCKER_IMAGE=$DOCKER_IMAGE" >> $GITHUB_OUTPUT
          echo "Build version: $VERSION"
          echo "Docker image: $DOCKER_IMAGE"

      - name: Log in to JFrog Artifactory Docker Registry
        uses: docker/login-action@v3
        with:
          registry: centraluhg.jfrog.io
          username: ${{ secrets.JFROG_USERNAME }}
          password: ${{ secrets.JFROG_SECRET }}

      - name: Build and push Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: Dockerfile
          push: true
          tags: centraluhg.jfrog.io/ppl-docker-np-loc/ppl/ppl-prun-utils:${{ env.BUILD_VERSION }}
          secrets: |
            JFROG_USERNAME=${{ secrets.JFROG_USERNAME }}
            JFROG_SECRET=${{ secrets.JFROG_SECRET }}

  # Job 2: Deploy to stage using the reusable workflow from ppl-prun-github-actions
  # The reusable workflow has the approvalToDeploy environment gate built in
  # Deploys to both CTC and ELR datacenters in parallel via matrix strategy
  deploy-stage:
    needs: build-and-push
    if: github.ref == 'refs/heads/develop' || startsWith(github.ref, 'refs/heads/release/')
    uses: uhc-tech-provider/ppl-prun-github-actions/.github/workflows/deploy.yml@main
    with:
      environment: "stage"
      dockerImage: ${{ needs.build-and-push.outputs.DOCKER_IMAGE }}
    secrets:
      KUBECONFIG: ${{ secrets.KUBECONFIG }}
      STAGE_VAULT_ROLE_ID: ${{ secrets.STAGE_VAULT_ROLE_ID }}
      STAGE_VAULT_SECRET_ID: ${{ secrets.STAGE_VAULT_SECRET_ID }}
      STAGE_KEYSTORE_PASS: ${{ secrets.STAGE_KEYSTORE_PASS }}
      STAGE_SPLUNK_TOKEN: ${{ secrets.STAGE_SPLUNK_TOKEN }}
      PROD_VAULT_ROLE_ID: ${{ secrets.PROD_VAULT_ROLE_ID }}
      PROD_VAULT_SECRET_ID: ${{ secrets.PROD_VAULT_SECRET_ID }}
      PROD_KEYSTORE_PASS: ${{ secrets.PROD_KEYSTORE_PASS }}
      PROD_SPLUNK_TOKEN: ${{ secrets.PROD_SPLUNK_TOKEN }}
      STAGE_DT_TOKEN: ${{ secrets.STAGE_DT_TOKEN }}
      PROD_DT_TOKEN: ${{ secrets.PROD_DT_TOKEN }}
