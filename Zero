class __VaultService:
    def __init__(self):
        logger.info("Instantiating Vault Service")

        try:
            self.base_namespace: str = "OPTUM/APP/FDS-PAPERLESS-LETTERS"
            self.config_path: str = "/secret/ppl-prun-utils/stage-properties"
            self.namespace: str = f"{self.base_namespace}/STAGE"
            self.vault_adapter = JSONAdapter(
                base_uri="https://pam-dev.uhc.com:443",
                verify=False,
                namespace=self.namespace,
            )
            # exposing app configs from vault as environment variable
            self.update_app_config()
            logger.info("Vault Service Instantiated Successfully")
        except Exception as ex:
            logger.error(
                f"Exception while initializing Vault Service: {str(ex)}. Trace: {traceback.format_exc()}"
            )
            raise

    def update_app_config(self) -> None:
        app_secrets: dict = self.__get_vault_secrets()
        for key, value in app_secrets.items():
            try:
                if key and value:
                    os.environ[key] = value
                else:
                    logger.error(f"Invalid key or value found")
            except Exception as e:
                logger.error(
                    f"Error setting some environment variable:, Error: {e}, Trace: {traceback.format_exc()}"
                )

    def __get_vault_token(self) -> str:
        try:
            approle = AppRole(adapter=self.vault_adapter)
            response = approle.login(
                role_id=os.getenv("VAULT_ROLE_ID"),
                secret_id=os.getenv("VAULT_SECRET_ID"),
                mount_point="approle",
                use_token=True,
            )
        except Exception as ex:
            logger.error(f"Exception while getting Vault Token: {str(ex)}. Trace: {traceback.format_exc()}")
            raise

        return self.vault_adapter.get_login_token(response)

    def __get_vault_secrets(self, client: hvac.Client = None) -> dict:
        vault_client = client if client else self.__get_vault_client()
        vault_data = vault_client.read(path=self.config_path)
        # print(vault_data)
        return vault_data["data"]

    def __get_vault_client(self) -> hvac.Client:
        token = self.__get_vault_token()
        return hvac.Client(
            url="https://pam-dev.uhc.com:443",
            token=token,
            verify=False,
            namespace=self.namespace,
        )


