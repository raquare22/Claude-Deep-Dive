apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Values.name }}-{{ .Values.environment }}
  namespace: {{ .Values.namespace }}
  labels:
    application: {{ .Values.name }}
    environment: {{ .Values.environment }}
    tier: app
spec:
  replicas: {{ .Values.replicas }}
  revisionHistoryLimit: {{ .Values.revisionHistoryLimit }}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 25%
      maxUnavailable: 25%
  # selector & template must match
  selector:
    matchLabels:
      application: {{ .Values.name }}
#          pr: ${pr}
      environment: {{ .Values.environment }}
  template:
    metadata:
      labels:
        application: {{ .Values.name }}
        environment: {{ .Values.environment }}
    spec:
      restartPolicy: Always
      dnsPolicy: ClusterFirst
      terminationGracePeriodSeconds: 30
      volumes:
        - name: logs
          persistentVolumeClaim:
            claimName: logs-{{ .Values.name }}-{{ .Values.environment }}
        - name: prun-log
          persistentVolumeClaim:
            claimName: prun-log-pvc
        - name: prun-pv
          persistentVolumeClaim:
            claimName: prun-pvc
        - name: prun-ehcache-pv
          persistentVolumeClaim:
            claimName: prun-ehcache-pvc
        - name: kafka
          persistentVolumeClaim:
            claimName: kafka-certs
      imagePullSecrets:
        - name: edge-docker-registry-secret
      containers:
        - name: {{ .Values.name }}-{{ .Values.environment }}
          image: {{ .Values.dockerImage }}
          imagePullPolicy: {{ .Values.pipeline.application.image.pullPolicy }}
          terminationMessagePath: /dev/termination-log
          ports:
            {{- if .Values.containerPorts }}
            {{- range .Values.containerPorts }}
            - name: {{ .name }}
              protocol: {{ .protocol }}
              containerPort: {{ .containerPort }}
            {{- end }}
            {{- end }}
          resources:
            limits:
              cpu: {{ .Values.resources.cpu.podLimit }}
              memory: {{ .Values.resources.memory.podLimit }}
            requests:
              cpu: {{ .Values.resources.cpu.podRequest }}
              memory: {{ .Values.resources.memory.podRequest }}
          volumeMounts:
            - name: logs
              mountPath: /app/logs
            {{- if .Values.volumes }}
            {{- range .Values.volumes }}
            - name: {{ .name }}
              mountPath: {{ .mountPath }}
            {{- end }}
            {{- end }}
          env:
            - name: LOG_LEVEL
              value: INFO
            - name: DT_HOST
              value: {{ .Values.dynatrace.host }}
            - name: DT_NETWORK_ZONE
              value: uhg.{{ .Values.datacenter }}.{{ .Values.dynatrace.zone }}
            - name: DT_CUSTOM_PROP
              value: Askid={{ .Values.dynatrace.askId }} Environment={{ .Values.dynatrace.environment }} Provider=uhg Location={{ .Values.datacenter }} Zone={{ .Values.dynatrace.zone }}
            - name: DT_API_TOKEN
              value: {{ .Values.dynatraceToken }}
            - name: APP_NAME
              value: {{ .Values.name }}
            - name: splunk.url
              value: {{ .Values.splunk.url }}
            - name: splunk.token
              value: {{ .Values.splunkToken }}
            - name: log.folder.path
              value: /prun-log/logs/{{ .Values.name }}
            - name: log.filename
              value: {{ .Values.name }}
            - name: JAVA_OPTS
              value: >
                -Xms{{ .Values.resources.memory.jvmMin }}
                -Xmx{{ .Values.resources.memory.jvmMax }}
                -Dk8.datacenter={{ .Values.datacenter }}
                -Dk8.zone={{ .Values.zone }}
                -Dspring.profiles.active=vault,git,{{ .Values.environment }}
                -Dvault.roleId={{ .Values.vaultRoleId }}
                -Dvault.secretId={{ .Values.vaultSecretId }}
                -Dencrypt.keyStore.location=classpath:stores/link-cfg-encryption-{{ .Values.encrypt.keystoreLocation }}.jks
                -Dencrypt.keyStore.password={{ .Values.keystorePassword }}
                -Dencrypt.keyStore.secret={{ .Values.keystorePassword }}
                -Dencrypt.keyStore.alias=link-config-encryption-{{ .Values.encrypt.keystoreAlias }}
                -Deureka.instance.hostname={{ .Values.name }}-{{ .Values.environment }}.hcck8s-{{ .Values.datacenter }}{{ .Values.eureka.host }}.optum.com
          livenessProbe:
            failureThreshold: 3
            initialDelaySeconds: 180
            periodSeconds: 5
            successThreshold: 1
            timeoutSeconds: {{ .Values.livenessProbe.timeoutSeconds }}
            httpGet:
              path: {{ .Values.livenessProbe.path }}
              port: 8080
              scheme: HTTP
          readinessProbe:
            failureThreshold: 3
            initialDelaySeconds: 240
            periodSeconds: 1
            successThreshold: 1
            timeoutSeconds: {{ .Values.readinessProbe.timeoutSeconds }}
            httpGet:
              path: {{ .Values.readinessProbe.path }}
              port: 8080
              scheme: HTTP
          securityContext:
            runAsUser: 1000
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            capabilities:
              drop:
                - KILL
                - MKNOD
                - SYS_CHROOT



























apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.name }}-{{ .Values.environment }}-ingress
  namespace: {{ .Values.namespace }}
  annotations:
    external-dns.alpha.kubernetes.io/hostname: {{ .Values.name}}-{{ .Values.environment }}.hcck8s-{{ .Values.datacenter }}-{{ .Values.ingressSubdomain }}.optum.com
    external-dns.alpha.kubernetes.io/ttl: "3600"
    nginx.ingress.kubernetes.io/proxy-body-size: "55m"
    nginx.ingress.kubernetes.io/rewrite-target: /
    nginx.ingress.kubernetes.io/ssl-redirect: "false"
  labels:
    application: {{ .Values.name }}
    environment: {{ .Values.environment }}
spec:
  ingressClassName: nginx
  rules:
    - host: {{ .Values.name}}-{{ .Values.environment }}.hcck8s-{{ .Values.datacenter }}-{{ .Values.ingressSubdomain }}.optum.com
      http:
        paths:
            - pathType: Prefix
              path: "/"
              backend:
                service:
                  name: {{ .Values.name }}-{{ .Values.environment }}-service
                  port:
                    number: 8080
    - host: {{ .Values.name }}-{{ .Values.environment }}.optum.com
      http:
        paths:
            - pathType: Prefix
              path: "/"
              backend:
                service:
                  name: {{ .Values.name }}-{{ .Values.environment }}-service
                  port:
                    number: 8080
    - host: {{ .Values.name }}-{{ .Values.environment }}-{{ .Values.datacenter }}.optum.com
      http:
        paths:
            - pathType: Prefix
              path: "/"
              backend:
                service:
                  name: {{ .Values.name }}-{{ .Values.environment }}-service
                  port:
                    number: 8080






















