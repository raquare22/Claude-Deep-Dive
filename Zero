{{/*
Templated equivalent of deployment/deployment.yml.
Output (after `helm template`) MUST match the current sed-substituted manifest
semantically. Verify with the parity-diff command before merging.
*/}}

{{- if not .Values.image.tag -}}
{{- fail "image.tag is required (pass via --set image.tag=<version>)" -}}
{{- end -}}
{{- if not .Values.vaultRoleId -}}
{{- fail "vaultRoleId is required (pass via --set vaultRoleId=...)" -}}
{{- end -}}
{{- if not .Values.vaultSecretId -}}
{{- fail "vaultSecretId is required (pass via --set vaultSecretId=...)" -}}
{{- end -}}

apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Values.name }}
  namespace: {{ .Values.namespace }}
  labels:
    app: {{ .Values.name }}
    app.kubernetes.io/name: {{ .Values.name }}
    app.kubernetes.io/instance: {{ .Release.Name }}
    app.kubernetes.io/version: {{ .Chart.AppVersion | quote }}
    app.kubernetes.io/managed-by: {{ .Release.Service }}
    helm.sh/chart: "{{ .Chart.Name }}-{{ .Chart.Version }}"
    environment: {{ .Values.environment }}
spec:
  replicas: {{ .Values.replicas }}
  revisionHistoryLimit: {{ .Values.revisionHistoryLimit }}
  selector:
    matchLabels:
      # IMMUTABLE after first deploy — must match today's deployment.yml exactly.
      # Adding any other key here breaks `helm upgrade` with "field is immutable".
      app: {{ .Values.name }}
  strategy:
    type: {{ .Values.strategy.type }}
    rollingUpdate:
      maxSurge: {{ .Values.strategy.rollingUpdate.maxSurge }}
      maxUnavailable: {{ .Values.strategy.rollingUpdate.maxUnavailable }}
  template:
    metadata:
      labels:
        # MUST be a superset of selector.matchLabels (here, exactly the same).
        app: {{ .Values.name }}
    spec:
      imagePullSecrets:
        - name: {{ .Values.imagePullSecret }}
      containers:
        - name: {{ .Values.name }}
          image: "{{ .Values.image.repository }}:{{ .Values.image.tag }}"
          imagePullPolicy: {{ .Values.image.pullPolicy }}
          ports:
            - containerPort: {{ .Values.containerPort }}
              protocol: TCP
          env:
            - name: VAULT_ROLE_ID
              value: {{ .Values.vaultRoleId | quote }}
            - name: VAULT_SECRET_ID
              value: {{ .Values.vaultSecretId | quote }}
          readinessProbe:
            tcpSocket:
              port: {{ .Values.containerPort }}
            initialDelaySeconds: {{ .Values.probes.initialDelaySeconds }}
            periodSeconds: {{ .Values.probes.periodSeconds }}
          livenessProbe:
            tcpSocket:
              port: {{ .Values.containerPort }}
            initialDelaySeconds: {{ .Values.probes.initialDelaySeconds }}
            periodSeconds: {{ .Values.probes.periodSeconds }}
          resources:
            limits:
              cpu: {{ .Values.resources.limits.cpu | quote }}
              memory: {{ .Values.resources.limits.memory }}
            requests:
              cpu: {{ .Values.resources.requests.cpu | quote }}
              memory: {{ .Values.resources.requests.memory }}
          securityContext:
            # HARDCODED — HCC compliance, do not parameterize
            runAsUser: 1000
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            capabilities:
              drop:
                - KILL
                - MKNOD
                - SYS_CHROOT
