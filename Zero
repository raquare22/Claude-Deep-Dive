          rallyMilestoneId: ${{ github.event.inputs.milestone }}
          precheck: "false"
          additionalReportRecipients: "ppl_support@ds.uhc.com"  # separated by comma without spaces (to send precheck report)
          comAutoClientId: ${{ env.COMAUTO_CLIENT_ID }}
          comAutoClientSecret: ${{ env.COMAUTO_CLIENT_SECRET }}

























name: deploy

on:
  workflow_call:
    inputs:
      environment:
        description: 'Environment to deploy to'
        required: true
        default: 'stage'
        type: string
      dockerImage:
        description: 'Docker image to deploy'
        required: true
        type: string
    secrets:
      KUBECONFIG:
        description: 'Kubeconfig for cluster access'
        required: true
      STAGE_VAULT_ROLE_ID:
        description: 'Vault role ID for stage'
        required: true
      STAGE_VAULT_SECRET_ID:
        description: 'Vault secret ID for stage'
        required: true
      STAGE_KEYSTORE_PASS:
        description: 'Keystore password for stage'
        required: true
      STAGE_SPLUNK_TOKEN:
        description: 'Splunk token for PRUN stage'
        required: true
      STAGE_DT_TOKEN:
        description: 'Dynatrace token for PRUN stage'
        required: false
      PROD_VAULT_ROLE_ID:
        description: 'Vault role ID for prod'
        required: true
      PROD_VAULT_SECRET_ID:
        description: 'Vault secret ID for prod'
        required: true
      PROD_KEYSTORE_PASS:
        description: 'Keystore password for prod'
        required: true
      PROD_SPLUNK_TOKEN:
        description: 'Splunk token for PRUN prod'
        required: true
      PROD_DT_TOKEN:
        description: 'Dynatrace token for PRUN prod'
        required: false

jobs:
  get-env-data:
    runs-on: uhg-runner
    outputs:
      matrix: ${{ steps.set.outputs.matrix}}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install yq
        run: |
          mkdir -p ~/.local/bin
          wget -qO ~/.local/bin/yq https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64
          chmod +x ~/.local/bin/yq
          echo "$HOME/.local/bin" >> $GITHUB_PATH
          echo "✅ Installed yq"  
      
      - name: Extract config
        uses: uhc-tech-provider/ppl-prun-github-actions/.github/actions/extract-config@main
        with:
          environment: ${{ inputs.environment}}

      # Use matrix to parallelize deployments across datacenters (CTC and ELR)
      - name: Export matrix
        id: set
        env:
          ENVIRONMENT: ${{ inputs.environment || 'stage' }}
        run: |
          # MATRIX=$(jq -c '{include: map({datacenter, cluster, namespace, api_server, cert_b64, cert_path, token_name, app_name, subdomain, f5value})}' deploy_data.json)

          MATRIX=$(jq -c '{include: map({datacenter, cluster_dns, cluster_name, namespace, app_name, api_server})}' deploy_data.json)
          
          
          echo "matrix<<EOF" >> $GITHUB_OUTPUT
          echo "$MATRIX" >> $GITHUB_OUTPUT
          echo "EOF" >> $GITHUB_OUTPUT

  deploy:
    runs-on: uhg-runner
    needs: get-env-data
    environment:
      name: approvalToDeploy
    strategy:
      matrix: ${{ fromJson(needs.get-env-data.outputs.matrix) }}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up kubectl
        uses: azure/setup-kubectl@v4.0.0
        with:
          version: 'latest'

      - name: Install yq
        run: |
          mkdir -p ~/.local/bin
          wget -qO ~/.local/bin/yq https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64
          chmod +x ~/.local/bin/yq
          echo "$HOME/.local/bin" >> $GITHUB_PATH
          echo "✅ Installed yq"  

      - name: Merge env files
        id: merged
        env:
          ENVIRONMENT: ${{ inputs.environment }}
        run: |
          # mkdir -p chart
          INPUT_ENV="helm/values-$ENVIRONMENT.yml"
          INPUT_COMMON="pipeline.yml"
          MERGED_FILE="helm/merged-values-$ENVIRONMENT.yml"
          ls pipeline.yml  1> /dev/null 2>&1 || { echo "::error::pipeline.yml file not found"; exit 1; }
          ls helm/values-$ENVIRONMENT.yml 1> /dev/null 2>&1 || { echo "::error::Input values-$ENVIRONMENT.yml file not found"; exit 1; }
          yq eval-all '... comments="" | . as $item ireduce ({}; . *+ $item)' "$INPUT_COMMON" "$INPUT_ENV" > "$MERGED_FILE" \
                || { echo "::error::Merge failed for $file"; exit 1; }  
          cat "$MERGED_FILE"

      - name: Print matrix values
        run: |
          echo "Datacenter: ${{ matrix.datacenter }}"
          echo "Cluster: ${{ matrix.cluster_dns }}"
          echo "Cluster Name: ${{ matrix.cluster_name }}"
          echo "Namespace: ${{ matrix.namespace }}"
          echo "API Server: ${{ matrix.api_server }}"
          echo "App Name: ${{ matrix.app_name }}"

      - name: Fetch secrets
        id: fetch-secrets
        env:
          ENVIRONMENT: ${{ inputs.environment }}
          STAGE_VAULT_ROLE_ID: ${{ secrets.STAGE_VAULT_ROLE_ID }}
          STAGE_VAULT_SECRET_ID: ${{ secrets.STAGE_VAULT_SECRET_ID }}
          STAGE_KEYSTORE_PASS: ${{ secrets.STAGE_KEYSTORE_PASS }}
          STAGE_SPLUNK_TOKEN: ${{ secrets.STAGE_SPLUNK_TOKEN }}
          PROD_VAULT_ROLE_ID: ${{ secrets.PROD_VAULT_ROLE_ID }}
          PROD_VAULT_SECRET_ID: ${{ secrets.PROD_VAULT_SECRET_ID }}
          PROD_KEYSTORE_PASS: ${{ secrets.PROD_KEYSTORE_PASS }}
          PROD_SPLUNK_TOKEN: ${{ secrets.PROD_SPLUNK_TOKEN }}
          STAGE_DT_TOKEN: ${{ secrets.STAGE_DT_TOKEN }}
          PROD_DT_TOKEN: ${{ secrets.PROD_DT_TOKEN }}
        run: |
          if [[ "$ENVIRONMENT" == "stage" || "$ENVIRONMENT" == "stage-pra" ]]; then
            vaultRoleId="$STAGE_VAULT_ROLE_ID"
            vaultSecretId="$STAGE_VAULT_SECRET_ID"
            keystorePass="$STAGE_KEYSTORE_PASS"
            splunkToken="$STAGE_SPLUNK_TOKEN"
            dynatraceToken="$STAGE_DT_TOKEN"
          elif [[ "$ENVIRONMENT" == "prod" || "$ENVIRONMENT" == "prod-pra" ]]; then
            vaultRoleId="$PROD_VAULT_ROLE_ID"
            vaultSecretId="$PROD_VAULT_SECRET_ID"
            keystorePass="$PROD_KEYSTORE_PASS"
            splunkToken="$PROD_SPLUNK_TOKEN"
            dynatraceToken="$PROD_DT_TOKEN"
          else
            echo "::error::Unknown environment: $ENVIRONMENT"
            exit 1
          fi

          echo "$STAGE_DT_TOKEN"
          echo "$PROD_DT_TOKEN"
          echo "Using Dynatrace token: $dynatraceToken"

          echo "vaultRoleId=$vaultRoleId" >> $GITHUB_ENV
          echo "vaultSecretId=$vaultSecretId" >> $GITHUB_ENV
          echo "keystorePass=$keystorePass" >> $GITHUB_ENV
          echo "splunkToken=$splunkToken" >> $GITHUB_ENV
          echo "dynatraceToken=$dynatraceToken" >> $GITHUB_ENV

      - name: Validate KUBECONFIG secret
        run: |
          if [ -z "${{ secrets.KUBECONFIG }}" ]; then
            echo "::error::KUBECONFIG secret is empty or missing."
            exit 1
          fi

      - name: Deploy to Kubernetes using helm
        id: deploy-k8s
        env:
          splunkToken: ${{ env.splunkToken }}
          vaultRoleId: ${{ env.vaultRoleId }}
          vaultSecretId: ${{ env.vaultSecretId }}
          keystorePass: ${{ env.keystorePass }}
          kubeconfig: ${{ secrets.KUBECONFIG }}
          dynatraceToken: ${{ env.dynatraceToken }}
          ENVIRONMENT: ${{ inputs.environment }}
          APP_NAME: ${{ matrix.app_name }}
        run: |
          set -e
          mkdir -p $HOME/.kube
          echo "$kubeconfig" > $HOME/.kube/config
          export KUBECONFIG=$HOME/.kube/config

          app_name="$APP_NAME"

          if [[ $ENVIRONMENT == "stage-pra" || $ENVIRONMENT == "prod-pra" ]]; then
            app_name="${APP_NAME}-pra"
          fi

          # Deploy App
          echo "Deploying app: $app_name"

          kubectl config get-contexts --kubeconfig $HOME/.kube/config

          context_name="${{ matrix.cluster_name }}-admin-token_${{ matrix.namespace }}"

          echo "Using context: $context_name"
          kubectl config use-context $context_name 

          kubectl auth whoami
          
          kubectl get pods

          helm upgrade $app_name ./helm \
            --install \
            --timeout 10m \
            --values ./helm/merged-values-$ENVIRONMENT.yml \
            --set dockerImage="${{inputs.dockerImage}}" \
            --set environment="$ENVIRONMENT" \
            --set datacenter="${{ matrix.datacenter }}" \
            --set keystorePassword="$keystorePass" \
            --set vaultRoleId="$vaultRoleId" \
            --set vaultSecretId="$vaultSecretId" \
            --set splunkToken="$splunkToken" \
            --set dynatraceToken="$dynatraceToken" \
            

            # --atomic \
            # --namespace ${{ matrix.namespace }} \
            # --kube-apiserver ${{ matrix.api_server }} \
            # --kubeconfig $HOME/.kube/config \
            # --set cluster="${{ matrix.cluster_name }}" \
            # --set cluster-port=443 \

          echo "✅ Successfully deployed to Datacenter: ${{ matrix.datacenter }}, Namespace: ${{ matrix.namespace }}"
          































name: Build and Deploy on EKS 
permissions:
  actions: read
  contents: write
  id-token: write
  pull-requests: read
  security-events: write
on:
  workflow_call:
    inputs:
      application-name:
        description: 'application name'
        required: true
        type: string
        default: 'pen'
env:
  AWS_REGION: us-east-1
  GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

jobs:
  prepare:
    runs-on: [ uhg-runner ]
    outputs:
      image_url: ${{ steps.prepare.outputs.image_url }}
      image_central_url: ${{ steps.prepare.outputs.image_central_url }}
      build_version: ${{ steps.prepare.outputs.build_version }}
      current_date: ${{ steps.prepare.outputs.current_date }}
      JFROG_PROJECT_KEY: ${{ steps.prepare.outputs.JFROG_PROJECT_KEY }}
    steps:              
    - name: Prepare environment variables
      id: prepare
      uses: uhc-tech-provider/ppl-prun-github-actions/.github/actions/prepare@main
      with:
        jfrogUsername: ${{ secrets.JFROG_USERNAME }}
        jfrogToken: ${{ secrets.JFROG_TOKEN }}

  build-and-quality-scans:
    needs: prepare
    if: needs.prepare.outputs.skip_build != 'true' && (github.event_name == 'pull_request' || startsWith(github.ref, 'refs/heads/MI') 
      || startsWith(github.ref, 'refs/heads/release/') || github.ref == 'refs/heads/develop'
      || github.ref == 'refs/heads/master')
    uses: uhg-pipelines/ci-workflows/.github/workflows/java-maven-ci.yml@v2.38.0
    with:
      docker-tags: ${{ needs.prepare.outputs.image_central_url }}
      jfrog-project-key: ${{ needs.prepare.outputs.JFROG_PROJECT_KEY }}
      java-version: "17"
      jfrog-create-release-bundle: false
      sonar-continue-on-error: true

  stage-deployment:
    # if: github.ref == 'refs/heads/aws-cloud-migration'
    if: always() && 
      !contains(needs.*.result, 'failure') &&
      !contains(needs.*.result, 'cancelled') &&
      (github.ref == 'refs/heads/develop' || startsWith(github.ref, 'refs/heads/MI') || startsWith(github.ref, 'refs/heads/release/'))
    needs: [prepare, build-and-quality-scans]
    runs-on: [ uhg-runner ]
    environment:
      name: approvalToDeploy
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Get secrets for AWS account access                                               
        id: secrets-from-immerse-vault
        uses: uhc-tech/volcan-ci/actions/secrets/get-secrets@v1.3
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          environment: 'stage'
          required-secrets: '["CODE_DEPLOY_ROLE", "EKS_CLUSTER_NAME", "NAMESPACE"]'
    
      - name: Configure AWS authentication                                           
        uses: aws-actions/configure-aws-credentials@v3
        with:
          role-to-assume: ${{ steps.secrets-from-immerse-vault.outputs.CODE_DEPLOY_ROLE }}
          aws-region: ${{ env.AWS_REGION }}

      - name: Print Docker Artifact Info
        run: |
          echo "Docker Image Tag: ${{ needs.prepare.outputs.image_url }}"

      - name: Setup kube-config and deploy at AWS EKS
        run: |
          aws eks --region ${{ env.AWS_REGION }} update-kubeconfig --name ${{ steps.secrets-from-immerse-vault.outputs.EKS_CLUSTER_NAME }}
          echo "-----------------------------------------------"
          echo "------DEPLOYING BELOW TEMPLATE ON AWS EKS------"
          echo "-----------------------------------------------"
          helm upgrade --install ${{ inputs.application-name }} ./helm \
            --namespace ${{ steps.secrets-from-immerse-vault.outputs.NAMESPACE }} \
            --values ./helm/values-stage.yaml \
            --set image.imagePath=${{ needs.prepare.outputs.image_url }} \
            --history-max 5
          echo "------DEPLOYED BELOW MANIFESTS SUCCESSFULLY ON AWS EKS------"
          helm template tmt -f ./helm/values-stage.yaml --set image.imagePath=${{ needs.prepare.outputs.image_url }} ./helm > final.yaml
          cat final.yaml

  prod-deployment:
    # if: github.ref == 'refs/heads/aws-prod-release'
    if: always() && 
      !contains(needs.*.result, 'failure') &&
      !contains(needs.*.result, 'cancelled') &&
      (github.ref == 'refs/heads/main' || startsWith(github.ref, 'refs/heads/master'))
    needs: [prepare, build-and-quality-scans]
    runs-on: [ uhg-runner ]
    environment:
      name: approvalToDeploy
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Get secrets for AWS account access                                               
        id: secrets-from-immerse-vault
        uses: uhc-tech/volcan-ci/actions/secrets/get-secrets@v1.3
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          environment: 'prod'
          required-secrets: '["CODE_DEPLOY_ROLE", "EKS_CLUSTER_NAME", "NAMESPACE"]'
    
      - name: Configure AWS authentication                                           
        uses: aws-actions/configure-aws-credentials@v3
        with:
          role-to-assume: ${{ steps.secrets-from-immerse-vault.outputs.CODE_DEPLOY_ROLE }}
          aws-region: ${{ env.AWS_REGION }}

      - name: Print Docker Artifact Info
        run: |
          echo "Docker Image Tag: ${{ needs.prepare.outputs.image_url }}"

      - name: Setup kube-config and deploy at AWS EKS
        run: |
          aws eks --region ${{ env.AWS_REGION }} update-kubeconfig --name ${{ steps.secrets-from-immerse-vault.outputs.EKS_CLUSTER_NAME }}
          echo "-----------------------------------------------"
          echo "------DEPLOYING BELOW TEMPLATE ON AWS EKS------"
          echo "-----------------------------------------------"
          helm upgrade --install ${{ inputs.application-name }} ./helm \
            --namespace ${{ steps.secrets-from-immerse-vault.outputs.NAMESPACE }} \
            --values ./helm/values-prod.yaml \
            --set image.imagePath=${{ needs.prepare.outputs.image_url }} \
            --history-max 5
          echo "------DEPLOYED BELOW MANIFESTS SUCCESSFULLY ON AWS EKS------"
          helm template tmt -f ./helm/values-prod.yaml --set image.imagePath=${{ needs.prepare.outputs.image_url }} ./helm > final.yaml
          cat final.yaml

  tag-release:
    #if: false # Always skip this job till cutover
