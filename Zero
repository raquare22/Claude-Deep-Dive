def _generate_message(receiverEmail) -> MIMEMultipart:
    SUBJECT = 'Processor Statuses'
    spaceIds = [8889, 8935, 8936, 8937, 8938, 10074, 10075, 10103, 10303, 10403, 10503, 10603, 10703, 10803, 10903, 11103, 11203, 11303, 11403, 11503, 11603, 11803]
    rowData = _populate_spaceIdsRowHtml(spaceIds)
    fmtMail = head + headData1.format(datetime.utcnow()) + rowData[0] + tail + headData2 + rowData[1] + mailTail
    message = MIMEMultipart("alternative", None, [MIMEText(fmtMail, 'html')])
    message['Subject'] = SUBJECT
    message['From'] = SENDER_EMAIL
    message['To'] = ", ".join(receiverEmail)
    return message


def send_processor_status():
    message = _generate_message(RECEIVER_EMAIL)
    server = smtplib.SMTP(SERVER)
    server.ehlo()
    server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, message.as_string())
    server.quit()


