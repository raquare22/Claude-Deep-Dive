        raise EnvironmentError("MONGO_URI_PRD environment variable is not set.")
    try:
        client = MongoClient(url, timeoutMS=180000, connectTimeoutMS=180000, maxPoolSize=150, minPoolSize=10, maxIdleTimeMS=60000)
    except Exception as e:
        # Log the error appropriately (replace print with proper logging in production)
        print(f"Failed to connect to MongoDB: {e}")
        raise
    return client['rulesEngineStore']


































