	private static final Logger LOGGER = LoggerFactory.getLogger(ProcessFileUnzip.class);

	@Value("${ENGINE_DELIGATE_URL}")
	private String engineDelegateUrl;
	
	@Value("${fileUnzipQueuesize}")
	private Integer fileUnzipQueueSize;
	
